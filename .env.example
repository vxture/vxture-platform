# =============================================================================
# Vxture environment template
# Copy this file to .env.local and fill real values before local startup.
# .env.local is ignored by git and must never be committed.
#
# Scope: root-level local startup for BFF services, agent servers, and AI gateway.
# dev-panel injects the root .env.local into local services. If a Next.js portal
# is started directly from its own directory, make sure NEXT_PUBLIC_* values are
# also available in that shell or the portal-specific .env.local.
# =============================================================================

# Runtime
NODE_ENV=development

# Database - PostgreSQL
DATABASE_URL=postgresql://postgres:CHANGE_ME_DB_PASSWORD@localhost:5432/vxturestudio_platform_main
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_DB_PASSWORD
DB_NAME=vxturestudio_platform_main
DB_POOL_MAX=10

# Cache - Redis
REDIS_URL=redis://localhost:6379

# Auth / JWT
# Production values must be at least 32 random characters.
JWT_SECRET=CHANGE_ME_JWT_SECRET_32_CHARS_MIN
# Refresh tokens must use a separate secret from JWT_SECRET.
JWT_REFRESH_SECRET=CHANGE_ME_JWT_REFRESH_SECRET_32_CHARS_MIN
JWT_ACCESS_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=30d
# Leave empty for local development. Use .vxture.com in production for shared
# cookies across platform subdomains.
AUTH_COOKIE_DOMAIN=

# Portal base URLs
WEBSITE_BASE_URL=http://localhost:3010
CONSOLE_BASE_URL=http://localhost:3020

# Service ports
GATEWAY_PORT=8000
AUTH_BFF_PORT=3090
WEBSITE_BFF_PORT=3011
CONSOLE_BFF_PORT=3021
ADMIN_BFF_PORT=3031
VARDA_BFF_PORT=3121
VARDA_SERVER_PORT=3122
MODEL_PLATFORM_PORT=3100

# Internal service URLs
MODEL_PLATFORM_URL=http://localhost:3100
VARDA_SERVER_INTERNAL_URL=http://localhost:3122
# Target auth-bff URL used by website-bff, console-bff, and admin-bff.
AUTH_BFF_URL=http://localhost:3090
# Gateway upstream origins used by gateway-bff in local development.
WEBSITE_BFF_ORIGIN=http://localhost:3011
CONSOLE_BFF_ORIGIN=http://localhost:3021
ADMIN_BFF_ORIGIN=http://localhost:3031
AUTH_BFF_ORIGIN=http://localhost:3090
GATEWAY_ALLOWED_ORIGINS=http://localhost:3010,http://localhost:3020,http://localhost:3030
# Shared internal service token. Production must set the same value in auth-bff
# and every BFF that calls auth-bff internal endpoints.
AUTH_INTERNAL_TOKEN=CHANGE_ME_AUTH_INTERNAL_TOKEN
# Admin portal base URL used by auth-bff OAuth allowlist handling.
ADMIN_BASE_URL=http://localhost:3030

# Email - Aliyun DirectMail SMTP
SMTP_HOST=smtpdm.aliyun.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=no-reply@mail.example.com
SMTP_PASS=CHANGE_ME_SMTP_PASSWORD
SMTP_FROM="Vxture Studio <no-reply@mail.example.com>"

# SMS - Aliyun SMS
ALIYUN_SMS_ACCESS_KEY_ID=CHANGE_ME_ALIYUN_SMS_ACCESS_KEY_ID
ALIYUN_SMS_ACCESS_KEY_SECRET=CHANGE_ME_ALIYUN_SMS_ACCESS_KEY_SECRET
ALIYUN_SMS_SIGN_NAME=CHANGE_ME_ALIYUN_SMS_SIGN_NAME
ALIYUN_SMS_TEMPLATE_CODE=SMS_000000000

# OAuth - DingTalk tenant login
DINGTALK_APP_KEY=CHANGE_ME_DINGTALK_APP_KEY
DINGTALK_APP_SECRET=CHANGE_ME_DINGTALK_APP_SECRET
# Must exactly match the OAuth callback URL configured in DingTalk Open Platform.
# Local: http://localhost:8000/auth-api/auth/oauth/dingtalk/callback
# Production: https://api.vxture.com/auth-api/auth/oauth/dingtalk/callback
DINGTALK_REDIRECT_URI=http://localhost:8000/auth-api/auth/oauth/dingtalk/callback

# OAuth - Feishu tenant login
FEISHU_APP_ID=CHANGE_ME_FEISHU_APP_ID
FEISHU_APP_SECRET=CHANGE_ME_FEISHU_APP_SECRET
FEISHU_REDIRECT_URI=http://localhost:8000/auth-api/auth/oauth/feishu/callback

# AI model - ByteDance Ark / Doubao
DOUBAO_API_KEY=CHANGE_ME_DOUBAO_API_KEY

# Varda agent
VARDA_DEFAULT_MODEL_CODE=doubao-seed-2-0-lite-260215
# Platform tenant UUID used for admin-surface LLM billing attribution.
VARDA_PLATFORM_LLM_TENANT_ID=CHANGE_ME_PLATFORM_TENANT_UUID
# Optional Model Platform agent UUID. Leave empty to meter by tenantId.
# VARDA_LLM_AGENT_ID=

# Cloudflare Turnstile
# When CF_TURNSTILE_ENABLED=true, the server enforces Turnstile verification
# for login, signup, and phone-code requests.
CF_TURNSTILE_ENABLED=false
NEXT_PUBLIC_CF_TURNSTILE_TENANT_SITE_KEY=
CF_TURNSTILE_TENANT_SECRET_KEY=
CF_TURNSTILE_TENANT_ALLOWED_HOSTNAMES=localhost,127.0.0.1,vxture.com,ruyin.ai
NEXT_PUBLIC_CF_TURNSTILE_ADMIN_SITE_ID=
CF_TURNSTILE_ADMIN_SECRET_KEY=
CF_TURNSTILE_ADMIN_ALLOWED_HOSTNAMES=localhost,127.0.0.1,admin.vxture.com

# Optional AI providers
# OPENAI_API_KEY=CHANGE_ME_OPENAI_API_KEY
# OPENAI_BASE_URL=https://api.openai.com/v1
# ANTHROPIC_API_KEY=CHANGE_ME_ANTHROPIC_API_KEY
# QWEN_API_KEY=your-qwen-api-key
# DEEPSEEK_API_KEY=your-deepseek-api-key

# Optional monitoring / analytics
# SENTRY_DSN=https://...@sentry.io/...
# POSTHOG_API_KEY=phc_...
# POSTHOG_HOST=https://app.posthog.com
