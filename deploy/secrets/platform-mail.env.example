# deploy/secrets/platform-mail.env
# Shared outbound mail credentials. Do not commit real values.
#
# compose.platform.yml injects this file only into BFF containers that send
# transactional email. Do not duplicate SMTP_* in .env.<service> files.

# Aliyun DirectMail SMTP
SMTP_HOST=smtpdm.aliyun.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=no-reply@mail.vxture.com
SMTP_PASS=CHANGEME
SMTP_FROM="Vxture Studio <no-reply@mail.vxture.com>"
