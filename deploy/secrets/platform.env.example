# deploy/secrets/platform.env
# Shared platform secrets generated by 12-generate-env-files.sh. Do not commit real values.
#
# compose.platform.yml injects this file through env_file into services that
# need database, Redis, JWT, or internal-auth credentials.
#
# Shared SMTP settings belong to secrets/platform-mail.env, not this file.

# Database
# Raw Postgres password file: secrets/pg-password
# Do not add POSTGRES_PASSWORD here.
#
# TD-018 (deploy/database/ddl/97_service_roles.sql, 98_column_locks.sql): a
# non-owner `platform_svc` role now exists in the DB with the same DML surface
# as `vxture` minus owner-bypass on anchor-column locks (id/*_no/created_at/
# created_by/admin.operator_role.rank). DATABASE_URL below is STILL `vxture`
# (today's actual deployed state) — switching it to `platform_svc` is a
# separate, explicitly-authorized production cutover (touches secrets +
# restarts all 5 platform containers: auth-bff/website-bff/console-bff/
# admin-bff/model-platform, which all share this file), NOT implied by this
# template update. See docs/tech-debt.md TD-018 for the cutover checklist.
DATABASE_URL=postgresql://vxture:CHANGEME@vx-platform-pg:5432/platform_main

# admin-bff reporting pool (read-only, TD-015). Falls back to DATABASE_URL
# (the RW/owner connection) when unset — see bff/admin-bff/src/providers/
# pools.module.ts `makePool`. TD-018 also created a `reporting_ro` role
# (SELECT-only, all 18 schemas); uncomment + point at it to close this
# fallback gap. Independent cutover, same caveats as DATABASE_URL above.
# REPORTING_RO_DATABASE_URL=postgresql://reporting_ro:CHANGEME@vx-platform-pg:5432/platform_main

# Redis
# Raw Redis password file: secrets/redis-password
# Do not add REDIS_PASSWORD here.
REDIS_URL=redis://:CHANGEME@vx-platform-redis:6379

# JWT shared by BFF services
JWT_SECRET=CHANGEME_32_CHARS_MIN
JWT_REFRESH_SECRET=CHANGEME_DIFFERENT_32_CHARS_MIN

# Internal service-to-service auth token
AUTH_INTERNAL_TOKEN=CHANGEME_RANDOM_TOKEN
