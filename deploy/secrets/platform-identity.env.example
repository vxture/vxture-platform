# deploy/secrets/platform-identity.env
# RS256 signing key for the IdP (auth-bff). Do not commit real values.
#
# Generated by provision-signing-key.mjs (run via 25-provision-signing-key.sh
# after migrate). The PUBLIC JWK is stored in iam.signing_key (served at
# /oidc/jwks); the PRIVATE key below is a secret and lives only here. Paste the
# two values the provision step prints, then re-run the deploy.

OIDC_ACTIVE_KID=CHANGEME
OIDC_SIGNING_PRIVATE_KEY=CHANGEME
