# deploy/.env.model-platform
# Runtime env for model-platform.
#
# DATABASE_URL is injected by compose.platform.yml through secrets/platform.env.

NODE_ENV=production
MODEL_PLATFORM_PORT=3100

# Provider API keys
# The apiKeyEnvVar field in AI model registry records must match one of these
# environment variable names.
DOUBAO_API_KEY=CHANGEME
# OPENAI_API_KEY=CHANGEME_OPENAI_API_KEY
# ANTHROPIC_API_KEY=CHANGEME_ANTHROPIC_API_KEY
