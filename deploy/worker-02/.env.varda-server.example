# deploy/worker-02/.env.varda-server.example  →  worker-02 本机 ./.env.varda-server
# varda-server 注册域 = [app, auth, varda, platform] + DATABASE_URL。VxConfig fail-fast。
# 完整必填以 packages/core/config/src/schemas/{app,auth,varda,platform}.schema.ts 为准。

# ── app ──
APP_ENV=production
NODE_ENV=production

# ── 本服务 ──
VARDA_SERVER_PORT=3122

# ── DB（本栈私有 varda-pg：Vela* 会话/消息/审计表）──
# 密码须与 ./secrets/varda-pg-password 一致。首部署需 prisma db push 建 Vela* 表（runbook §4）。
DATABASE_URL=postgresql://varda:CHANGE_ME_VARDA_PG_PASSWORD@varda-pg:5432/varda

# ── auth ──
# 与 varda-bff 的 JWT_SECRET 同值
JWT_SECRET=CHANGE_ME_SAME_AS_PLATFORM_JWT_SECRET
# auth.schema 必填（≥32 字符）。varda 代码不消费它，但 VxConfig fail-fast 校验要求存在；
# 与平台 platform.env 的 JWT_REFRESH_SECRET 同值即可。
JWT_REFRESH_SECRET=CHANGE_ME_SAME_AS_PLATFORM_JWT_REFRESH_SECRET

# ── platform（唯一跨主机硬依赖：LLM 网关 = worker-01 model-platform）──
# worker-01 model-platform 已绑 tailscale IP 暴露（compose.platform.yml，见 runbook §3）。
MODEL_PLATFORM_URL=http://100.100.197.42:3100

# ── varda ──
VARDA_PLATFORM_LLM_TENANT_ID=CHANGE_ME_PLATFORM_TENANT_UUID
# 必须是 model.models 里 is_active 且 ARK key 实际可调用的 model_code。
# doubao-seed-2-0-lite-260215 已于 2026-07-11 注册进生产目录并实测（seed 的 doubao-pro-32k 在该 ARK 账号不存在，勿用）。
VARDA_DEFAULT_MODEL_CODE=doubao-seed-2-0-lite-260215
# VARDA_LLM_AGENT_ID=
