# deploy/worker-02/.env.varda-bff.example  →  worker-02 本机 ./.env.varda-bff
# varda-bff 注册域 = [app, auth, redis, platform]。VxConfig fail-fast：缺任一必填
# 字段容器启动即退出 → 首部署务必看 `docker logs vx-varda-bff`。
# 完整必填字段以权威 schema 为准：packages/core/config/src/schemas/{app,auth,redis,platform}.schema.ts
# 共享字段（APP_ENV/JWT_SECRET 等）命名与平台一致，可对照 deploy/.env.example。

# ── app ──
APP_ENV=production
NODE_ENV=production

# ── 本服务 ──
VARDA_BFF_PORT=3080
# admin / console 站点 origin（CORS）
ALLOWED_ORIGIN=https://admin.vxture.com,https://console.vxture.com

# ── auth ──
# 与平台会话签名 JWT_SECRET 同值（owner 转运）；varda-bff 用它验 admin/console access cookie
JWT_SECRET=CHANGE_ME_SAME_AS_PLATFORM_JWT_SECRET
# auth.schema 必填（≥32 字符）。varda 代码不消费它，但 VxConfig fail-fast 校验要求存在；
# 与平台 platform.env 的 JWT_REFRESH_SECRET 同值即可（须与 .env.varda-server 一致）。
JWT_REFRESH_SECRET=CHANGE_ME_SAME_AS_PLATFORM_JWT_REFRESH_SECRET

# ── redis（jti 撤销黑名单；RedisService 断链时 fail-open 跳过撤销检查）──
# 默认用本栈私有 varda-redis（无密码）。
# 若要与平台跨服务撤销强一致：改指 worker-01 平台 redis（需其暴露到 Tailscale + 密码），
#   并接受"跨主机 redis 断链 = varda 鉴权全挂"的 fail-closed 代价（见 runbook §5）。
REDIS_URL=redis://varda-redis:6379

# ── platform ──
# 反代到同栈 varda-server（compose 网络内解析）
VARDA_SERVER_INTERNAL_URL=http://varda-server:3081
