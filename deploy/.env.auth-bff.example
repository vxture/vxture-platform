# deploy/.env.auth-bff
# Runtime env for auth-bff. This service is the tenant auth source and the
# centralized JWT / cookie issuer.
#
# Shared platform secrets are injected by compose.platform.yml through
# secrets/platform.env. Shared mail credentials through secrets/platform-mail.env.
# Shared SMS credentials (phone-code login) through secrets/platform-sms.env.
# The RS256 signing key is injected through secrets/platform-identity.env.
# Do not duplicate DATABASE_URL, REDIS_URL, JWT_SECRET, JWT_REFRESH_SECRET,
# AUTH_INTERNAL_TOKEN, SMTP_*, ALIYUN_SMS_*, or OIDC_SIGNING_PRIVATE_KEY here.

NODE_ENV=production
AUTH_BFF_PORT=3090
DB_POOL_MAX=10

# JWT runtime options
JWT_ACCESS_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=30d
AUTH_COOKIE_DOMAIN=.vxture.com
COOKIE_DOMAIN_PLATFORM=.vxture.com

# Tenant (customer) central session TTLs (FB-006, owner 2026-07-06): idle 4h /
# absolute 1d (tightened from the code fallback 7d). Set explicitly here — the
# authoritative value is env-driven, not a code default.
OIDC_SESSION_IDLE_TTL=14400
OIDC_SESSION_ABS_TTL=86400

# Operator central session (vx_sid_op) TTLs — shorter than tenant for the
# high-privilege control plane (operator-identity-security.md §2.3). Defaults:
# idle 1800s (30min) / absolute 28800s (8h, covers a workday). Override here if needed.
OPERATOR_SESSION_IDLE_TTL=1800
OPERATOR_SESSION_ABS_TTL=28800

# OIDC issuer + interactive login surface (both are the accounts surface).
# The RS256 signing key (OIDC_ACTIVE_KID + OIDC_SIGNING_PRIVATE_KEY) is a secret
# produced by provision-signing-key.mjs and injected via
# secrets/platform-identity.env — see the deploy runbook.
OIDC_ISSUER=https://accounts.vxture.com
LOGIN_UI_BASE_URL=https://accounts.vxture.com

# Portal base URLs — build seed oidc_client redirect_uris / back_channel / post_logout.
# Each value MUST match the registered domain exactly (else 400 invalid_redirect_uri).
# Same-site portals (website/console/admin):
WEBSITE_BASE_URL=https://vxture.com
CONSOLE_BASE_URL=https://console.vxture.com
ADMIN_BASE_URL=https://admin.vxture.com
# Cross-domain saas apps (prod only; no beta for umbra):
# umbra = the RP at ruyin.ai (ex-ruyin, renamed per product_300 §2 — domain unchanged).
UMBRA_BASE_URL=https://ruyin.ai
RUNA_BASE_URL=https://runa.ai
NOCUS_BASE_URL=https://nocus.vxture.com
ATLAS_BASE_URL=https://atlas.vxture.com
ONTOS_BASE_URL=https://ontos.vxture.com
RAVEN_BASE_URL=https://raven.vxture.com
ANLAN_BASE_URL=https://anlan.ai
FORGE_BASE_URL=https://forge.vxture.com
XUANZHEN_BASE_URL=https://xuanzhen.ai
# Same-site saas apps on *.vxture.com (deployed on vx-worker-02 via Tailscale; nginx proxies arda.vxture.com):
ARDA_BASE_URL=https://arda.vxture.com
# Tailnet provisioning-webhook delivery target (product_230 §3.1): seeds ONLY
# product_webhooks.webhook_url — decoupled from ARDA_BASE_URL (which also seeds
# the public OIDC redirect_uris). Empty = fall back to ARDA_BASE_URL (public edge).
# Production value = arda's tailscale IP:port on vx-worker-02 (owner-provisioned).
ARDA_WEBHOOK_BASE_URL=
# ruyin = NEW client-side product surface (NOT ruyin.ai — that is UMBRA_BASE_URL):
RUYIN_BASE_URL=https://ruyin.vxture.com
# Beta variants — pattern: https://beta-{code}.vxture.com (same-site) or https://beta.{domain} (cross-domain).
# Leave empty until the beta deployment for that app goes live; empty = no beta redirect_uri registered.
RUYIN_BETA_BASE_URL=https://beta-ruyin.vxture.com
RUNA_BETA_BASE_URL=https://beta-runa.vxture.com
NOCUS_BETA_BASE_URL=https://beta-nocus.vxture.com
ATLAS_BETA_BASE_URL=https://beta-atlas.vxture.com
ONTOS_BETA_BASE_URL=https://beta-ontos.vxture.com
RAVEN_BETA_BASE_URL=https://beta-raven.vxture.com
ANLAN_BETA_BASE_URL=https://beta-anlan.vxture.com
FORGE_BETA_BASE_URL=https://beta-forge.vxture.com
XUANZHEN_BETA_BASE_URL=https://beta-xuanzhen.vxture.com
ARDA_BETA_BASE_URL=https://beta-arda.vxture.com

# Sample seed user (zhangsan) password — Argon2id PHC hash, projected to the seed
# by 23-seed. The PLAINTEXT is never stored here or in the repo; only this hash.
# Leave as CHANGEME to skip seeding the sample user. Generate with the platform
# hasher (hash-wasm argon2id, m=65536 t=3 p=1, 32-byte).
SAMPLE_USER_PASSWORD_HASH=CHANGEME

# Operator superadmin password — Argon2id PHC hash (runtime secret).
# REQUIRED before seeding a production DB: the Admin@2026 bootstrap default is
# public in this repo, so the 23/29 seed runners fail closed when
# NODE_ENV=production and this is unset (non-production keeps the default +
# force-change-on-first-login). Generate with the platform hasher (hash-wasm
# argon2id, m=65536 t=3 p=1). SINGLE-QUOTE the value ('$argon2id$...') — the
# seed scripts source this file, and an unquoted/double-quoted PHC hash is
# $-expanded into garbage. Projected to the seed container by
# 23-seed-platform-database.sh / 29-seed-platform-ddl.sh.
OPERATOR_SUPERADMIN_PASSWORD_HASH=

# Operator superadmin contact (optional, seed-projected like the hash above).
# Seeded into admin.operator_account email/phone; empty → fresh seed leaves
# them null and a re-seed keeps existing DB values (coalesce in on-conflict).
# Owner PII is no longer hardcoded in seed-catalog (2026-07-21).
OPERATOR_SUPERADMIN_EMAIL=
OPERATOR_SUPERADMIN_PHONE=

# Operator TOTP secret encryption key (AES-256-GCM, derived to 32 bytes via
# SHA-256). Encrypts admin.operator_mfa.totp_secret at rest — the base32 plaintext
# is never stored. Auto-provisioned (random) by 27-provision-client-secrets.sh on
# on the deploy host; leave empty here. When unset at runtime operator TOTP enroll/verify
# fails closed (operator_totp_unavailable). See operator-identity-security.md §9.
OPERATOR_TOTP_ENC_KEY=

# Operator WebAuthn / Passkey relying-party config (operator-identity-security.md
# §2.1/§9). RP_ID = the registrable domain of the operator login surface;
# ORIGIN = its exact origin. REQUIRED for operator WebAuthn: when unset, passkey
# registration fails closed (operator_webauthn_unavailable). RP_NAME defaults to
# Vxture. Operator login renders on the accounts surface, so these track it.
OPERATOR_WEBAUTHN_RP_ID=accounts.vxture.com
OPERATOR_WEBAUTHN_RP_NAME=Vxture
OPERATOR_WEBAUTHN_ORIGIN=https://accounts.vxture.com

# Cloudflare Turnstile - tenant + operator surfaces
# CF_TURNSTILE_ENABLED gates ALL server-side verification (env gate): when false
# the IdP skips Turnstile entirely. Operator-realm login (ops.admin) is verified
# with the ADMIN keys below; the operator login UI runs on the accounts surface,
# so its allowed hostname is accounts.vxture.com (the page hostname, not admin.*).
# To enable operator Turnstile: set CF_TURNSTILE_ADMIN_SECRET_KEY here, set the
# CF_TURNSTILE_ADMIN_SITE_KEY CI secret (baked into the accounts build), and keep
# CF_TURNSTILE_ENABLED=true. See bff/auth-bff/src/oidc/operator-login-guard.service.ts.
CF_TURNSTILE_ENABLED=true
CF_TURNSTILE_TENANT_SECRET_KEY=CHANGEME
# Tenant login now renders on the central accounts surface (accounts.vxture.com);
# legacy embedded surfaces (vxture.com/console.vxture.com) and umbra (ruyin.ai)
# remain for any in-page widgets that still post to the IdP.
CF_TURNSTILE_TENANT_ALLOWED_HOSTNAMES=accounts.vxture.com,vxture.com,console.vxture.com,ruyin.ai
CF_TURNSTILE_ADMIN_SECRET_KEY=CHANGEME
CF_TURNSTILE_ADMIN_ALLOWED_HOSTNAMES=accounts.vxture.com

# OAuth - social login (Google / Feishu / DingTalk). Brokered inbound OAuth is
# wired (Batch 16d): the IdP serves /auth/oauth/<provider>/{start,callback} and
# /auth/oauth/bind-phone. The seed marks each provider is_enabled only when BOTH
# its client id + secret are set (CHANGEME → disabled). The REDIRECT_URI must
# (1) match the route exactly: <issuer>/auth/oauth/<provider>/callback, and
# (2) be added to the provider console's authorized-redirect whitelist.
# Issuer = accounts.vxture.com; accounts nginx routes /auth/* → auth-bff.

# OAuth - Google
GOOGLE_CLIENT_ID=CHANGEME
GOOGLE_CLIENT_SECRET=CHANGEME
GOOGLE_REDIRECT_URI=https://accounts.vxture.com/auth/oauth/google/callback

# OAuth - Feishu
FEISHU_APP_ID=CHANGEME
FEISHU_APP_SECRET=CHANGEME
FEISHU_REDIRECT_URI=https://accounts.vxture.com/auth/oauth/feishu/callback

# OAuth - DingTalk
DINGTALK_APP_KEY=CHANGEME
DINGTALK_APP_SECRET=CHANGEME
DINGTALK_REDIRECT_URI=https://accounts.vxture.com/auth/oauth/dingtalk/callback

# Confidential RP client secret hashes (bcrypt). NOT consumed by auth-bff at
# runtime — they live here because 23-seed sources this file and projects them
# into iam.oidc_client.client_secret_hash, which the IdP verifies against the RP-
# presented OIDC_CLIENT_SECRET (bcryptjs.compare). Generated + filled by
# scripts/27-provision-client-secrets.sh (single-quoted there so `. source` does
# not expand the '$' segments). Empty → strict env-audit blocks deploy; missing
# hash → RP token exchange fails 401 invalid_client. Pairs with OIDC_CLIENT_SECRET
# in .env.{website,console,admin}-bff. Cross-domain RP hashes (umbra and future saas
# apps) live here; plaintext secrets are transported off-box (27-provision writes to
# 0600 files, not local RP envs). Add a hash entry when each new RP is provisioned.
# UMBRA inherits the legacy RUYIN hash (db-init migration shim, product_300 §2.4);
# RUYIN below now names the NEW client-side product (unprovisioned until it ships).
OIDC_CLIENT_SECRET_HASH_WEBSITE=
OIDC_CLIENT_SECRET_HASH_CONSOLE=
OIDC_CLIENT_SECRET_HASH_ADMIN=
OIDC_CLIENT_SECRET_HASH_UMBRA=
OIDC_CLIENT_SECRET_HASH_RUYIN=
OIDC_CLIENT_SECRET_HASH_RUNA=
OIDC_CLIENT_SECRET_HASH_NOCUS=
OIDC_CLIENT_SECRET_HASH_ATLAS=
OIDC_CLIENT_SECRET_HASH_ONTOS=
OIDC_CLIENT_SECRET_HASH_RAVEN=
OIDC_CLIENT_SECRET_HASH_ANLAN=
OIDC_CLIENT_SECRET_HASH_FORGE=
OIDC_CLIENT_SECRET_HASH_XUANZHEN=
OIDC_CLIENT_SECRET_HASH_ARDA=
OIDC_CLIENT_SECRET_HASH_ARDA_BETA=
