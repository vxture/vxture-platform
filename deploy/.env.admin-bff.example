# deploy/.env.admin-bff
# Runtime env for admin-bff. This service is an OIDC RP for the operator realm:
# operator login (and its Turnstile) run on the IdP (auth-bff); admin-bff reads
# the operator RP session and verifies no Turnstile itself.
#
# Shared platform secrets are injected by compose.platform.yml through
# secrets/platform.env. Shared mail credentials are injected through
# secrets/platform-mail.env. Do not duplicate DATABASE_URL, REDIS_URL,
# JWT_SECRET, JWT_REFRESH_SECRET, AUTH_INTERNAL_TOKEN, or SMTP_* here.

NODE_ENV=production
ADMIN_BFF_PORT=3031
DB_POOL_MAX=10

# JWT runtime options
JWT_ACCESS_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=30d
AUTH_COOKIE_DOMAIN=.vxture.com

# Internal service URLs
AUTH_BFF_URL=http://vx-platform-auth-bff:3090

# OIDC issuer = public IdP face (accounts surface). The RP builds the browser
# authorize redirect + discovery from this; MUST be the public issuer, not the
# localhost schema default. See docs/design/identity-access-topology.md.
OIDC_ISSUER=https://accounts.vxture.com

# This RP's own public origin. The RP derives its redirect_uri
# (${ADMIN_BASE_URL}/auth/callback) + allowed return origins from it; MUST be the
# public host, not the localhost schema default — otherwise the IdP rejects
# authorize with 400 invalid_redirect_uri (the registered redirect_uris are
# https://admin.vxture.com/auth/callback).
ADMIN_BASE_URL=https://admin.vxture.com

# Confidential RP client secret. The browser client_id is "admin"; this secret
# authenticates the RP at the IdP token endpoint. Generated + filled by
# scripts/27-provision-client-secrets.sh; the matching bcrypt hash lands in
# .env.auth-bff (OIDC_CLIENT_SECRET_HASH_ADMIN) → seed → iam.oidc_client. Empty
# here blocks deploy via strict env-audit; unfilled at runtime → RP token
# exchange fails 401 invalid_client.
OIDC_CLIENT_SECRET=

# ARDA_PROVISION_WEBHOOK_SECRET moved to .env.platform-api (product_310 D13):
# the provisioning dispatcher now runs in platform-api, not admin-bff.
