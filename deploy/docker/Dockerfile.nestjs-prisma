# syntax=docker/dockerfile:1
# Dockerfile.nestjs-prisma — NestJS 服务 Dockerfile（esbuild + Prisma Client）
# 适用于：agent-server/varda（@vxture/agent-server-varda）、services/model/platform（@vxture/service-model-platform）
# 构建参数：
#   SERVICE_PATH    服务相对路径，如 agent-server/varda
#   PACKAGE_FILTER  pnpm 包名，如 @vxture/agent-server-varda
#   PRISMA_SCHEMA   schema 文件相对路径，如 agent-server/varda/prisma/schema.prisma
#
# 用法（从 repo 根目录执行）：
#   docker build -f deploy/docker/Dockerfile.nestjs-prisma \
#     --build-arg SERVICE_PATH=agent-server/varda \
#     --build-arg PACKAGE_FILTER=@vxture/agent-server-varda \
#     --build-arg PRISMA_SCHEMA=agent-server/varda/prisma/schema.prisma \
#     -t ghcr.io/vxture/agent-varda:latest .

ARG NODE_VERSION=24

# ── 构建层 ────────────────────────────────────────────────────────────────────
FROM node:${NODE_VERSION}-alpine AS builder
WORKDIR /repo

RUN corepack enable && corepack prepare pnpm@10.30.3 --activate

COPY pnpm-workspace.yaml pnpm-lock.yaml package.json tsconfig.base.json ./
COPY packages/ packages/
COPY services/ services/
COPY agent-server/ agent-server/
COPY bff/ bff/
COPY portals/ portals/
COPY agent-studio/ agent-studio/
COPY business/ business/
# tools/dev-panel is excluded from build context (dev-only) but pnpm needs it as workspace stub
RUN mkdir -p tools/dev-panel && echo '{"name":"@vxture/dev-panel","version":"0.0.0"}' > tools/dev-panel/package.json

# B7: pnpm store 走 BuildKit cache mount —— 源码改动触发 install 重跑时依赖从持久
# store 取（downloaded 0）。Prisma generate 产物写入 node_modules（后续归集到 /runtime），
# 不放入 cache mount，避免运行时产物因 mount 临时性丢失。
RUN --mount=type=cache,id=pnpm-store,target=/pnpm/store \
    pnpm install --frozen-lockfile --store-dir /pnpm/store

ARG SERVICE_PATH
ARG PACKAGE_FILTER
ARG PRISMA_SCHEMA

# 生成 Linux 平台的 Prisma query engine（容器内执行，确保平台匹配）
RUN pnpm --filter ${PACKAGE_FILTER} exec prisma generate --schema=/repo/${PRISMA_SCHEMA}

RUN pnpm --filter ${PACKAGE_FILTER} build

# 将运行时所需文件归集到 /runtime，避免运行层使用条件 COPY
RUN mkdir -p /runtime/node_modules && \
    cp ${SERVICE_PATH}/dist/main.cjs /runtime/main.cjs && \
    { [ -d "${SERVICE_PATH}/src/generated/prisma" ] && \
        mkdir -p /runtime/src/generated/prisma && \
        find ${SERVICE_PATH}/src/generated/prisma -name "*.so.node" -exec cp {} /runtime/src/generated/prisma/ \; || true; } && \
    { [ -d "node_modules/.prisma" ]         && cp -rL node_modules/.prisma         /runtime/node_modules/ || true; } && \
    { [ -d "node_modules/@prisma" ]         && cp -rL node_modules/@prisma         /runtime/node_modules/ || true; } && \
    { [ -d "${SERVICE_PATH}/node_modules/.prisma" ] && cp -rL ${SERVICE_PATH}/node_modules/.prisma /runtime/node_modules/ || true; } && \
    { [ -d "${SERVICE_PATH}/node_modules/@prisma" ] && cp -rL ${SERVICE_PATH}/node_modules/@prisma /runtime/node_modules/ || true; }

# ── 运行层 ────────────────────────────────────────────────────────────────────
FROM node:${NODE_VERSION}-alpine AS runner
WORKDIR /app

ENV NODE_ENV=production

RUN apk add --no-cache curl \
  && addgroup --system --gid 1001 nodejs \
  && adduser --system --uid 1001 nodeapp

COPY --from=builder --chown=nodeapp:nodejs /runtime ./

USER nodeapp

CMD ["node", "main.cjs"]
