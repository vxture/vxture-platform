# deploy/.env.platform-api
# Runtime env for platform-api — the product-facing S2S host (product_310 D13):
# C2 entitlements/visible-set reads, C3 consume/gauge writes, and the commerce
# background jobs (provisioning dispatch, sharing/trial expiry sweeps).
#
# Shared platform secrets are injected by compose.platform.yml through
# secrets/platform.env (+ platform-app.env for the platform_svc DB role).
# Do not duplicate DATABASE_URL, REDIS_URL, JWT_SECRET, JWT_REFRESH_SECRET,
# or AUTH_INTERNAL_TOKEN here.
#
# No OIDC RP identity: this host serves no browser traffic. It only VERIFIES
# IdP-minted S2S bearer tokens against the IdP JWKS (fetched from AUTH_BFF_URL
# over the internal network — the signing private key stays in auth-bff).

NODE_ENV=production
PLATFORM_API_PORT=3041
DB_POOL_MAX=10

# Internal IdP URL — JWKS back-channel for S2S bearer verification.
AUTH_BFF_URL=http://vx-auth-bff:3090

# Expected `iss` of IdP-minted S2S tokens (public issuer face).
OIDC_ISSUER=https://accounts.vxture.com

# Arda provisioning webhook HMAC secret (product_310 P2.3, host moved here by
# D13). product.product_webhooks stores only this VAR NAME as
# webhook_secret_ref, resolved from the dispatcher's process env at delivery
# time to sign POST ${ARDA_BASE_URL}/provisioning/webhook
#   x-vxture-signature: t=<ts>,v1=hex(HMAC_SHA256(secret, "{t}.{raw_body}"))
# MUST equal PROVISION_WEBHOOK_SECRET on the arda host (owner transfers the
# value out-of-band; generate with `openssl rand -hex 32`). Optional until the
# arda webhook goes live — unset means deliveries retry to dead-letter.
ARDA_PROVISION_WEBHOOK_SECRET=

# Job cadences (ms) — defaults built in; override only when tuning.
# PROVISION_DISPATCH_INTERVAL_MS=10000
# SHARING_EXPIRY_SWEEP_INTERVAL_MS=60000
# TRIAL_EXPIRY_SWEEP_INTERVAL_MS=60000
