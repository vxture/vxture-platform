# deploy/.env.website-bff
# Runtime env for website-bff. Auth requests are delegated to auth-bff.
#
# Shared platform secrets are injected by compose.platform.yml through
# secrets/platform.env. Shared mail credentials are injected through
# secrets/platform-mail.env. Do not duplicate DATABASE_URL, REDIS_URL,
# JWT_SECRET, JWT_REFRESH_SECRET, AUTH_INTERNAL_TOKEN, or SMTP_* here.

NODE_ENV=production
WEBSITE_BFF_PORT=3011
DB_POOL_MAX=10

# JWT runtime options
JWT_ACCESS_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=30d
AUTH_COOKIE_DOMAIN=.vxture.com

# Internal service URLs
AUTH_BFF_URL=http://vx-platform-auth-bff:3090

# OIDC issuer = public IdP face (accounts surface). The RP builds the browser
# authorize redirect + discovery from this; MUST be the public issuer, not the
# localhost schema default. See docs/design/identity-access-topology.md.
OIDC_ISSUER=https://accounts.vxture.com

# Confidential RP client secret. The browser client_id is "website"; this secret
# authenticates the RP at the IdP token endpoint. Generated + filled by
# scripts/27-provision-client-secrets.sh; the matching bcrypt hash lands in
# .env.auth-bff (OIDC_CLIENT_SECRET_HASH_WEBSITE) → seed → iam.oidc_client. Empty
# here blocks deploy via strict env-audit; unfilled at runtime → RP token
# exchange fails 401 invalid_client.
OIDC_CLIENT_SECRET=

# Portal base URLs
WEBSITE_BASE_URL=https://vxture.com
CONSOLE_BASE_URL=https://console.vxture.com
