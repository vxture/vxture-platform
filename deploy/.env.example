# deploy/.env
# Optional Docker Compose variable overrides. 12-generate-env-files.sh generates this file
# automatically only when it does not already exist. Do not commit real values.
#
# Infrastructure raw passwords live in secrets/pg-password and
# secrets/redis-password. Service containers receive REDIS_URL from
# secrets/platform.env. Shared SMTP settings live in secrets/platform-mail.env.

# Optional image source variables. GitHub Actions injects these during automated
# production deployment. Manual deployments may uncomment and set them as needed.
# VX_IMAGE_REGISTRY=crpi-l3l7g186zpo2if7p.cn-hangzhou.personal.cr.aliyuncs.com
# VX_IMAGE_NAMESPACE=vxture
# VX_IMAGE_TAG=latest
