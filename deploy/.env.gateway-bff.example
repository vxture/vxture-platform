# deploy/.env.gateway-bff
# Runtime env for gateway-bff, the public API proxy.
# Copy this file to .env.gateway-bff and fill real values.

NODE_ENV=production
GATEWAY_PORT=8000

# Upstream BFF origins inside the Docker network
WEBSITE_BFF_ORIGIN=http://vx-platform-website-bff:3011
CONSOLE_BFF_ORIGIN=http://vx-platform-console-bff:3021
ADMIN_BFF_ORIGIN=http://vx-platform-admin-bff:3031
AUTH_BFF_ORIGIN=http://vx-platform-auth-bff:3090

# CORS allowlist
GATEWAY_ALLOWED_ORIGINS=https://vxture.com,https://www.vxture.com,https://console.vxture.com,https://admin.vxture.com
