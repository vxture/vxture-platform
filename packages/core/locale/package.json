{
  "name": "@vxture/core-locale",
  "version": "1.2.2",
  "description": "Vxture platform — core localization/i18n infrastructure",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rimraf dist && tsup",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@vxture/shared": "workspace:*"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
