  operatorRemark String?  @map("operator_remark") @db.VarChar(512)
  clientIp       String?  @map("client_ip") @db.VarChar(64)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  subscription TenantSubscription @relation(fields: [subscriptionId], references: [id])

  @@index([changeType], map: "idx_tscl_change_type")
  @@index([createdAt], map: "idx_tscl_created_at")
  @@index([subscriptionId], map: "idx_tscl_subscription_id")
  @@index([tenantId], map: "idx_tscl_tenant_id")
  @@map("tenant_subscription_history")
  @@schema("commerce")
}

// 交易流水，不可更新/删除（DB RULE 强制），append-only
model TenantTransaction {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  billId        String?  @map("bill_id") @db.Uuid
  transactionNo String   @unique(map: "tenant_bill_transaction_transaction_no_key") @map("transaction_no") @db.VarChar(64)
  tradeType     String   @map("trade_type") @db.VarChar(32)
  amount        Decimal  @db.Decimal(12, 2)
  currency      String?  @default("CNY") @db.VarChar(16)
  balanceBefore Decimal  @map("balance_before") @db.Decimal(12, 2)
  balanceAfter  Decimal  @map("balance_after") @db.Decimal(12, 2)
  tradeStatus   String   @default("success") @map("trade_status") @db.VarChar(32)
  relatedNo     String?  @map("related_no") @db.VarChar(128)
  remark        String?  @db.VarChar(512)
  operatorId    String?  @map("operator_id") @db.Uuid
  clientIp      String?  @map("client_ip") @db.VarChar(64)
  createdBy     String   @map("created_by") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([tenantId], map: "idx_tt_tenant_id")
  @@index([tradeType], map: "idx_tt_trade_type")
  @@index([transactionNo], map: "idx_tt_transaction_no")
  @@map("tenant_transaction")
  @@schema("commerce")
}

// 账户余额快照；余额变动流水在 tenant_transaction
model TenantCredit {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String   @unique(map: "tenant_credit_tenant_id_key") @map("tenant_id") @db.Uuid
  currency       String   @default("CNY") @db.VarChar(16)
  balance        Decimal  @default(0) @db.Decimal(12, 2)
  totalGranted   Decimal  @default(0) @map("total_granted") @db.Decimal(12, 2)
  totalConsumed  Decimal  @default(0) @map("total_consumed") @db.Decimal(12, 2)
  version        Int      @default(0)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@index([tenantId], map: "idx_tc_credit_tenant_id")
  @@map("tenant_credit")
  @@schema("commerce")
}

model TenantBillingAddress {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  invoiceType String    @map("invoice_type") @db.VarChar(32)
  title       String    @db.VarChar(256)
  taxNo       String?   @map("tax_no") @db.VarChar(64)
  phone       String?   @db.VarChar(64)
  address     String?   @db.VarChar(512)
  bankName    String?   @map("bank_name") @db.VarChar(256)
  bankAccount String?   @map("bank_account") @db.VarChar(256)
  isDefault   Boolean   @default(false) @map("is_default")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  @@index([tenantId], map: "idx_tba_tenant_id")
  @@map("tenant_billing_address")
  @@schema("commerce")
}

model TenantPaymentMethod {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  methodType  String    @map("method_type") @db.VarChar(32)
  status      String    @default("active") @db.VarChar(32)
  displayName String    @map("display_name") @db.VarChar(128)
  externalId  String?   @map("external_id") @db.VarChar(256)
  isDefault   Boolean   @default(false) @map("is_default")
  lastUsedAt  DateTime? @map("last_used_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  @@index([tenantId], map: "idx_tpm_tenant_id")
  @@index([status], map: "idx_tpm_status")
  @@map("tenant_payment_method")
  @@schema("commerce")
}

// ═══════════════════════════════════════════════════════════════
// schema: model（从 model_platform 迁入，去除 api_key_env_var）
// ═══════════════════════════════════════════════════════════════

model ModelProvider {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  providerCode String    @unique(map: "model_provider_code_key") @map("provider_code") @db.VarChar(64)
  providerType String    @default("online") @map("provider_type") @db.VarChar(32)
  providerName String    @map("provider_name") @db.VarChar(128)
  description  String?   @db.VarChar(512)
  logoUrl      String?   @map("logo_url") @db.Text
  homepageUrl  String?   @map("homepage_url") @db.Text
  consoleUrl   String?   @map("console_url") @db.Text
  billingUrl   String?   @map("billing_url") @db.Text
  isActive     Boolean   @default(true) @map("is_active")
  config       Json?     @db.JsonB
  createdBy    String?   @map("created_by") @db.Uuid
  updatedBy    String?   @map("updated_by") @db.Uuid
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)

  models ModelDefinition[]

  @@index([isActive], map: "idx_model_provider_is_active")
  @@index([providerType], map: "idx_model_provider_type")
  @@map("model_provider")
  @@schema("model")
}

// model 是 Prisma 关键字（小写），Prisma 模型名用 ModelDefinition 避免混淆
model ModelDefinition {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  providerId        String?   @map("provider_id") @db.Uuid
  modelCode         String    @unique(map: "model_definition_code_key") @map("model_code") @db.VarChar(128)
  modelType         String    @default("chat") @map("model_type") @db.VarChar(32)
  protocol          String    @db.VarChar(64)
  modelName         String    @map("model_name") @db.VarChar(128)
  description       String?   @db.VarChar(512)
  endpointUrl       String    @map("endpoint_url") @db.Text
  contextWindow     Int?      @map("context_window")
  maxOutputTokens   Int?      @map("max_output_tokens")
  capabilities      String[]  @default([])
  supportsStreaming  Boolean   @default(true) @map("supports_streaming")
  isActive          Boolean   @default(true) @map("is_active")
  sort              Int       @default(999)
  config            Json?     @db.JsonB
  createdBy         String?   @map("created_by") @db.Uuid
  updatedBy         String?   @map("updated_by") @db.Uuid
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt         DateTime? @map("deleted_at") @db.Timestamptz(6)

  providerRef ModelProvider?    @relation(fields: [providerId], references: [id])
  grants      ModelGrant[]
  priceRules  ModelPriceRule[]
  policies    ModelPolicy[]

  @@index([isActive], map: "idx_model_def_is_active")
  @@index([modelType], map: "idx_model_def_type")
  @@index([providerId], map: "idx_model_def_provider_id")
  @@map("model")
  @@schema("model")
}

model ModelGrant {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  modelId   String    @map("model_id") @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  applicationId   String?   @map("application_id") @db.Uuid
  applicationType String?   @map("application_type") @db.VarChar(32)
  agentId   String?   @map("agent_id") @db.Uuid
  priority  Int       @default(100)
  isActive  Boolean   @default(true) @map("is_active")
  reason    String?   @db.VarChar(512)
  expiresAt DateTime? @map("expires_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  modelDef ModelDefinition @relation(fields: [modelId], references: [id])

  @@index([applicationId], map: "idx_model_grant_application")
  @@index([applicationType], map: "idx_model_grant_application_type")
  @@index([agentId], map: "idx_model_grant_agent")
  @@index([isActive], map: "idx_model_grant_is_active")
  @@index([modelId], map: "idx_model_grant_model")
  @@index([tenantId], map: "idx_model_grant_tenant")
  @@map("model_grant")
  @@schema("model")
}

model ModelPriceRule {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  modelId          String    @map("model_id") @db.Uuid
  billingMode      String    @default("token") @map("billing_mode") @db.VarChar(32)
  currency         String    @default("CNY") @db.VarChar(16)
  unitTokens       Int       @default(1000000) @map("unit_tokens")
  inputUnitPrice   Decimal   @default(0) @map("input_unit_price") @db.Decimal(18, 8)
  outputUnitPrice  Decimal   @default(0) @map("output_unit_price") @db.Decimal(18, 8)
  requestUnitPrice Decimal   @default(0) @map("request_unit_price") @db.Decimal(18, 8)
  isActive         Boolean   @default(true) @map("is_active")
  effectiveAt      DateTime  @default(now()) @map("effective_at") @db.Timestamptz(6)
  expiresAt        DateTime? @map("expires_at") @db.Timestamptz(6)
  createdBy        String?   @map("created_by") @db.Uuid
  updatedBy        String?   @map("updated_by") @db.Uuid
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  modelDef ModelDefinition @relation(fields: [modelId], references: [id])

  @@index([effectiveAt], map: "idx_model_price_effective")
  @@index([isActive], map: "idx_model_price_is_active")
  @@index([modelId], map: "idx_model_price_model")
  @@map("model_price_rule")
  @@schema("model")
}

model ModelPolicy {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  modelId           String    @map("model_id") @db.Uuid
  tenantId          String?   @map("tenant_id") @db.Uuid
  name              String?   @db.VarChar(128)
  priority          Int       @default(100)
  maxConcurrent     Int?      @map("max_concurrent")
  rateLimitRpm      Int?      @map("rate_limit_rpm")
  rateLimitTpm      BigInt?   @map("rate_limit_tpm")
  rateLimitTpd      BigInt?   @map("rate_limit_tpd")
  maxContextTokens  Int?      @map("max_context_tokens")
  isActive          Boolean   @default(true) @map("is_active")
  effectiveAt       DateTime  @default(now()) @map("effective_at") @db.Timestamptz(6)
  expiresAt         DateTime? @map("expires_at") @db.Timestamptz(6)
  createdBy         String?   @map("created_by") @db.Uuid
  updatedBy         String?   @map("updated_by") @db.Uuid
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  modelDef ModelDefinition @relation(fields: [modelId], references: [id])

  @@unique([modelId, tenantId], map: "model_policy_model_tenant_key")
  @@index([isActive], map: "idx_model_policy_is_active")
  @@index([modelId], map: "idx_model_policy_model")
  @@index([tenantId], map: "idx_model_policy_tenant")
  @@map("model_policy")
  @@schema("model")
}

// ═══════════════════════════════════════════════════════════════
// schema: admin（原 ops，2026-07-02 改名；运营身份 operator_* + 平台治理）
// ═══════════════════════════════════════════════════════════════

// ── operator identity domain (operator_*) — docs/design/identity-platform-operator.md §6 ──
// Fully isolated from identity.* / iam.role|permission: no FK, no cross-read.

model OperatorAccount {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roleId      String    @map("role_id") @db.Uuid
  username    String    @unique(map: "uidx_operator_account_username") @db.VarChar(64)
  email       String?   @unique(map: "uidx_operator_account_email") @db.VarChar(128)
  phone       String?   @unique(map: "uidx_operator_account_phone") @db.VarChar(32)
  displayName String    @default("") @map("display_name") @db.VarChar(50)
  status      String    @default("active") @db.VarChar(32)
  accountType String    @default("personal") @map("account_type") @db.VarChar(16)
  sort        Int       @default(999)
  lastLoginAt DateTime? @map("last_login_at") @db.Timestamptz(6)
  lastLoginIp String?   @map("last_login_ip") @db.VarChar(64)
  remark      String?   @db.VarChar(255)
  createdBy   String?   @map("created_by") @db.Uuid
  updatedBy   String?   @map("updated_by") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  role                OperatorRole                 @relation(fields: [roleId], references: [id])
  credential          OperatorCredential?
  mfa                 OperatorMfa?
  webauthnCredentials OperatorWebauthnCredential[]
  recoveryCodes       OperatorRecoveryCode[]
  refreshTokens       OperatorRefreshToken[]

  @@index([roleId], map: "idx_operator_account_role_id")
  @@index([status], map: "idx_operator_account_status")
  @@index([deletedAt], map: "idx_operator_account_deleted_at")
  @@index([sort], map: "idx_operator_account_sort")
  @@map("operator_account")
  @@schema("admin")
}

model OperatorCredential {
  operatorId          String    @id @map("operator_id") @db.Uuid
  passwordHash        String?   @map("password_hash") @db.VarChar(255)
  passwordChangedAt   DateTime? @map("password_changed_at") @db.Timestamptz(6)
  forcePasswordChange Boolean   @default(false) @map("force_password_change")
  failedAttempts      Int       @default(0) @map("failed_attempts")
  lockedUntil         DateTime? @map("locked_until") @db.Timestamptz(6)
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  account OperatorAccount @relation(fields: [operatorId], references: [id], onDelete: Cascade)

  @@map("operator_credential")
  @@schema("admin")
}

model OperatorMfa {
  operatorId       String    @id @map("operator_id") @db.Uuid
  policy           String    @default("optional") @db.VarChar(16)
  totpSecret       String?   @map("totp_secret") @db.VarChar(255)
  totpEnabled      Boolean   @default(false) @map("totp_enabled")
  totpConfirmedAt  DateTime? @map("totp_confirmed_at") @db.Timestamptz(6)
  webauthnRequired Boolean   @default(false) @map("webauthn_required")
  enrolledAt       DateTime? @map("enrolled_at") @db.Timestamptz(6)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  account OperatorAccount @relation(fields: [operatorId], references: [id], onDelete: Cascade)

  @@map("operator_mfa")
  @@schema("admin")
}

model OperatorWebauthnCredential {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  operatorId   String    @map("operator_id") @db.Uuid
  credentialId String    @unique(map: "uidx_operator_webauthn_credential_id") @map("credential_id") @db.VarChar(255)
  publicKey    Bytes     @map("public_key")
  signCount    BigInt    @default(0) @map("sign_count")
  aaguid       String?   @db.VarChar(64)
  transports   String[]
  label        String?   @db.VarChar(64)
  lastUsedAt   DateTime? @map("last_used_at") @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  account OperatorAccount @relation(fields: [operatorId], references: [id], onDelete: Cascade)

  @@index([operatorId], map: "idx_operator_webauthn_credential_operator_id")
  @@map("operator_webauthn_credential")
  @@schema("admin")
}

model OperatorRecoveryCode {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  operatorId String    @map("operator_id") @db.Uuid
  codeHash   String    @map("code_hash") @db.VarChar(255)
  usedAt     DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  account OperatorAccount @relation(fields: [operatorId], references: [id], onDelete: Cascade)

  @@index([operatorId], map: "idx_operator_recovery_code_operator_id")
  @@map("operator_recovery_code")
  @@schema("admin")
}

model OperatorVerification {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  operatorId   String?   @map("operator_id") @db.Uuid
  targetType   String    @map("target_type") @db.VarChar(16)
  target       String    @db.VarChar(128)
  purpose      String    @db.VarChar(32)
  codeHash     String    @map("code_hash") @db.VarChar(64)
  attemptCount Int       @default(0) @map("attempt_count")
  expiresAt    DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt       DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([target, expiresAt], map: "idx_operator_verification_target_expires")
  @@index([operatorId], map: "idx_operator_verification_operator_id")
  @@map("operator_verification")
  @@schema("admin")
}

model OperatorLoginAttempt {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  operatorId String?  @map("operator_id") @db.Uuid
  identifier String   @db.VarChar(128)
  authMethod String   @default("password") @map("auth_method") @db.VarChar(32)
  result     String   @db.VarChar(32)
  ipAddress  String   @map("ip_address") @db.VarChar(64)
  userAgent  String?  @map("user_agent") @db.VarChar(512)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([identifier, createdAt(sort: Desc)], map: "idx_operator_login_attempt_identifier_created")
  @@index([ipAddress, createdAt(sort: Desc)], map: "idx_operator_login_attempt_ip_created")
  @@index([operatorId], map: "idx_operator_login_attempt_operator_id")
  @@map("operator_login_attempt")
  @@schema("admin")
}

model OperatorRefreshToken {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  operatorId  String   @map("operator_id") @db.Uuid
  sessionId   String   @map("session_id") @db.VarChar(64)
  clientId    String   @default("admin") @map("client_id") @db.VarChar(64)
  tokenHash   String   @unique(map: "uidx_operator_refresh_token_hash") @map("token_hash") @db.VarChar(64)
  rotatedFrom String?  @map("rotated_from") @db.Uuid
  status      String   @default("active") @db.VarChar(16)
  expiresAt   DateTime @map("expires_at") @db.Timestamptz(6)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  account OperatorAccount @relation(fields: [operatorId], references: [id], onDelete: Cascade)

  @@index([operatorId], map: "idx_operator_refresh_token_operator_id")
  @@index([sessionId], map: "idx_operator_refresh_token_session_id")
  @@index([expiresAt], map: "idx_operator_refresh_token_expires_at")
  @@map("operator_refresh_token")
  @@schema("admin")
}

model OperatorRole {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roleCode           String   @unique(map: "uidx_operator_role_code") @map("role_code") @db.VarChar(64)
  status             String   @default("active") @db.VarChar(32)
  nameEn             String   @map("name_en") @db.VarChar(128)
  nameI18nKey        String   @map("name_i18n_key") @db.VarChar(128)
  description        String   @default("") @db.VarChar(255)
  descriptionI18nKey String?  @map("description_i18n_key") @db.VarChar(128)
  isSystem           Boolean  @default(false) @map("is_system")
  sort               Int      @default(999)
  mfaMinLevel        String   @default("optional") @map("mfa_min_level") @db.VarChar(16)
  createdBy          String?  @map("created_by") @db.Uuid
  updatedBy          String?  @map("updated_by") @db.Uuid
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  accounts        OperatorAccount[]
  rolePermissions OperatorRolePermission[]

  @@index([status], map: "idx_operator_role_status")
  @@index([sort], map: "idx_operator_role_sort")
  @@map("operator_role")
  @@schema("admin")
}

// 支持自引用父子树结构
model OperatorPermission {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  parentId    String?  @map("parent_id") @db.Uuid
  permCode    String   @unique(map: "uidx_operator_permission_code") @map("perm_code") @db.VarChar(64)
  permType    String   @map("perm_type") @db.VarChar(20)
  permName    String   @map("perm_name") @db.VarChar(64)
  routePath   String?  @map("route_path") @db.VarChar(255)
  component   String?  @db.VarChar(255)
  icon        String?  @db.VarChar(64)
  description String   @default("") @db.VarChar(255)
  isActive    Boolean  @default(true) @map("is_active")
  isVisible   Boolean  @default(true) @map("is_visible")
  sort        Int      @default(999)
  createdBy   String   @map("created_by") @db.Uuid
  updatedBy   String   @map("updated_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  parent          OperatorPermission?      @relation("OperatorPermParent", fields: [parentId], references: [id])
  children        OperatorPermission[]     @relation("OperatorPermParent")
  rolePermissions OperatorRolePermission[]

  @@index([parentId], map: "idx_operator_permission_parent_id")
  @@index([permType], map: "idx_operator_permission_type")
  @@index([sort], map: "idx_operator_permission_sort")
  @@map("operator_permission")
  @@schema("admin")
}

// 角色权限关联，复合主键，无更新语义（硬删除）
model OperatorRolePermission {
  roleId       String   @map("role_id") @db.Uuid
  permissionId String   @map("permission_id") @db.Uuid
  createdBy    String   @map("created_by") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  role       OperatorRole       @relation(fields: [roleId], references: [id])
  permission OperatorPermission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
  @@map("operator_role_permission")
  @@schema("admin")
}

model OpsSetting {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  configGroup    String   @map("config_group") @db.VarChar(64)
  configKey      String   @unique(map: "uk_ops_setting_key") @map("config_key") @db.VarChar(128)
  valueType      String   @default("string") @map("value_type") @db.VarChar(20)
  configValue    String   @map("config_value") @db.Text
  isSensitive    Boolean  @default(false) @map("is_sensitive")
  isEncrypted    Boolean  @default(false) @map("is_encrypted")
  isReadonly     Boolean  @default(false) @map("is_readonly")
  validationRule String?  @map("validation_rule") @db.VarChar(512)
  description    String?  @db.Text
  createdBy      String?  @map("created_by") @db.Uuid
  updatedBy      String?  @map("updated_by") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@index([configGroup], map: "idx_ops_setting_group")
  @@map("setting")
  @@schema("admin")
}

// 治理记录，id 为 varchar(64) 非 UUID，与 kind 构成复合主键
// GIN index on tags 由原始 DDL 管理（Prisma 不支持 GIN 声明）
// 风控记录（§14.4.5，拆自 governance_record；采纳 database.md §3.7）。tenant/reviewer 逻辑引用无 FK。
model RiskRecord {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  riskLevel   String    @default("normal") @map("risk_level") @db.VarChar(32)
  riskScore   Int?      @map("risk_score")
  scope       String?   @db.VarChar(160)
  reason      String    @default("") @db.Text
  reviewerId  String?   @map("reviewer_id") @db.Uuid
  tags        String[]  @default([])
  sourceTable String?   @map("source_table") @db.VarChar(128)
  sourceId    String?   @map("source_id") @db.VarChar(128)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  @@index([tenantId, riskLevel], map: "idx_admin_risk_record_tenant")
  @@map("risk_record")
  @@schema("admin")
}

// 合规事件记录（§14.4.5，拆自 governance_record）。event_type/status 枚举待业务（runbook §18.4）。
model ComplianceEvent {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String?   @map("tenant_id") @db.Uuid
  eventType      String    @map("event_type") @db.VarChar(64)
  status         String    @default("open") @db.VarChar(32)
  regulationCode String?   @map("regulation_code") @db.VarChar(64)
  evidenceUrl    String?   @map("evidence_url") @db.Text
  handlerId      String?   @map("handler_id") @db.Uuid
  detail         Json?     @db.JsonB
  tags           String[]  @default([])
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(6)

  @@index([tenantId, status], map: "idx_admin_compliance_event_tenant")
  @@map("compliance_event")
  @@schema("admin")
}

model OpsFeatureFlag {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  flagKey            String    @unique(map: "ops_feature_flag_key_key") @map("flag_key") @db.VarChar(128)
  category           String    @default("release") @db.VarChar(64)
  environment        String    @default("all") @db.VarChar(32)
  description        String?   @db.VarChar(512)
  isGloballyEnabled  Boolean   @default(false) @map("is_globally_enabled")
  isArchived         Boolean   @default(false) @map("is_archived")
  rolloutPercentage  Int       @default(0) @map("rollout_percentage")
  tenantOverrides    Json      @default("{}") @map("tenant_overrides") @db.JsonB
  expiresAt          DateTime? @map("expires_at") @db.Timestamptz(6)
  createdBy          String?   @map("created_by") @db.Uuid
  updatedBy          String?   @map("updated_by") @db.Uuid
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@index([category], map: "idx_ops_ff_category")
  @@index([environment], map: "idx_ops_ff_environment")
  @@map("feature_flag")
  @@schema("admin")
}

model OpsAnnouncement {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  announcementType    String    @map("announcement_type") @db.VarChar(32)
  severity            String    @default("info") @db.VarChar(16)
  status              String    @default("draft") @db.VarChar(32)
  lang                String    @default("zh-CN") @db.VarChar(16)
  title               String    @db.VarChar(256)
  content             String    @db.Text
  ctaLabel            String?   @map("cta_label") @db.VarChar(64)
  ctaUrl              String?   @map("cta_url") @db.VarChar(512)
  targetPlans         String[]  @default([]) @map("target_plans") @db.VarChar(64)
  targetTenantTypes   String[]  @default([]) @map("target_tenant_types") @db.VarChar(32)
  isDismissible       Boolean   @default(true) @map("is_dismissible")
  publishAt           DateTime  @map("publish_at") @db.Timestamptz(6)
  expiresAt           DateTime? @map("expires_at") @db.Timestamptz(6)
  meta                Json?     @db.JsonB
  createdBy           String    @map("created_by") @db.Uuid
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt           DateTime? @map("deleted_at") @db.Timestamptz(6)

  @@index([publishAt], map: "idx_ops_ann_publish_at")
  @@index([status], map: "idx_ops_ann_status")
  @@map("announcement")
  @@schema("admin")
}

model OpsMaintenance {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  severity           String    @default("minor") @db.VarChar(16)
  status             String    @default("scheduled") @db.VarChar(32)
  title              String    @db.VarChar(256)
  description        String?   @db.Text
  impactDescription  String?   @map("impact_description") @db.Text
  affectedServices   String[]  @default([]) @map("affected_services") @db.VarChar(64)
  startAt            DateTime  @map("start_at") @db.Timestamptz(6)
  endAt              DateTime  @map("end_at") @db.Timestamptz(6)
  actualEndAt        DateTime? @map("actual_end_at") @db.Timestamptz(6)
  createdBy          String    @map("created_by") @db.Uuid
  updatedBy          String?   @map("updated_by") @db.Uuid
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@index([startAt], map: "idx_ops_maint_start_at")
  @@index([status], map: "idx_ops_maint_status")
  @@map("maintenance")
  @@schema("admin")
}

// ═══════════════════════════════════════════════════════════════
// schema: support
// ═══════════════════════════════════════════════════════════════

model SupportTicket {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId            String    @map("tenant_id") @db.Uuid
  accountId           String?   @map("account_id") @db.Uuid
  ticketNo            String    @unique(map: "uq_support_ticket_no") @map("ticket_no") @db.VarChar(64)
  category            String    @default("general") @db.VarChar(64)
  priority            String    @default("p2") @db.VarChar(16)
  source              String    @default("console") @db.VarChar(64)
  status              String    @default("open") @db.VarChar(32)
  title               String    @db.VarChar(200)
  description         String    @default("") @db.Text
  reporterName        String?   @map("reporter_name") @db.VarChar(100)
  assigneeId          String?   @map("assignee_id") @db.Uuid
  assigneeName        String?   @map("assignee_name") @db.VarChar(100)
  tags                String[]  @default([]) @db.VarChar(64)
  satisfactionScore   Int?      @map("satisfaction_score")
  satisfactionComment String?   @map("satisfaction_comment") @db.VarChar(512)
  slaBreachAt         DateTime? @map("sla_breach_at") @db.Timestamptz(6)
  firstResponseAt     DateTime? @map("first_response_at") @db.Timestamptz(6)
  dueAt               DateTime? @map("due_at") @db.Timestamptz(6)
  resolvedAt          DateTime? @map("resolved_at") @db.Timestamptz(6)
  closedAt            DateTime? @map("closed_at") @db.Timestamptz(6)
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt           DateTime? @map("deleted_at") @db.Timestamptz(6)

  comments SupportTicketComment[]

  @@index([deletedAt], map: "idx_support_ticket_deleted_at")
  @@index([priority, updatedAt(sort: Desc)], map: "idx_support_ticket_priority_updated")
  @@index([tenantId, status], map: "idx_support_ticket_tenant_status")
  @@map("ticket")
  @@schema("support")
}

// 工单事件流水，append-only
model SupportTicketComment {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticketId  String   @map("ticket_id") @db.Uuid
  eventType String   @map("event_type") @db.VarChar(64)
  actorType String   @map("actor_type") @db.VarChar(32)
  actorId   String?  @map("actor_id") @db.Uuid
  actorName String   @map("actor_name") @db.VarChar(100)
  payload   Json     @default("{}") @db.JsonB
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId, createdAt(sort: Desc)], map: "idx_support_ticket_comment_ticket_created")
  @@map("ticket_comment")
  @@schema("support")
}

// 操作审计，append-only，按月 RANGE 分区（Prisma 不支持分区声明，由 DDL 管理）
model SupportAuditLog {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actorType    String   @map("actor_type") @db.VarChar(32)
  actorId      String   @map("actor_id") @db.Uuid
  tenantId     String?  @map("tenant_id") @db.Uuid
  action       String   @db.VarChar(128)
  result       String   @default("success") @db.VarChar(32)
  resourceType String   @map("resource_type") @db.VarChar(64)
  resourceId   String   @map("resource_id") @db.VarChar(128)
  errorCode    String?  @map("error_code") @db.VarChar(64)
  before       Json?    @db.JsonB
  after        Json?    @db.JsonB
  requestId    String?  @map("request_id") @db.VarChar(128)
  durationMs   Int?     @map("duration_ms")
  ipAddress    String?  @map("ip_address") @db.VarChar(64)
  userAgent    String?  @map("user_agent") @db.VarChar(512)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([actorId], map: "idx_audit_log_actor_id")
  @@index([action], map: "idx_audit_log_action")
  @@index([createdAt], map: "idx_audit_log_created_at")
  @@index([requestId], map: "idx_audit_log_request_id")
  @@index([tenantId], map: "idx_audit_log_tenant_id")
  @@map("audit_log")
  @@schema("support")
}

// 通知发送流水，append-only
model SupportNotificationLog {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String?   @map("tenant_id") @db.Uuid
  accountId         String?   @map("account_id") @db.Uuid
  channel           String    @db.VarChar(32)
  templateCode      String    @map("template_code") @db.VarChar(64)
  status            String    @db.VarChar(32)
  referenceType     String?   @map("reference_type") @db.VarChar(64)
  referenceId       String?   @map("reference_id") @db.VarChar(128)
  recipient         String    @db.VarChar(256)
  subject           String?   @db.VarChar(256)
  provider          String?   @db.VarChar(64)
  providerMessageId String?   @map("provider_message_id") @db.VarChar(256)
  errorMessage      String?   @map("error_message") @db.Text
  retryCount        Int       @default(0) @map("retry_count")
  deliveredAt       DateTime? @map("delivered_at") @db.Timestamptz(6)
  openedAt          DateTime? @map("opened_at") @db.Timestamptz(6)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([accountId], map: "idx_notif_log_account_id")
  @@index([channel], map: "idx_notif_log_channel")
  @@index([status], map: "idx_notif_log_status")
  @@index([tenantId], map: "idx_notif_log_tenant_id")
  @@map("notification_log")
  @@schema("support")
}

// ═══════════════════════════════════════════════════════════════
// schema: safety（内容安全 / 风控 / 合规事件；§13。新建域）
// 设计依据：docs/design/platform-data-architecture-schema.md §13
// ═══════════════════════════════════════════════════════════════

// 审核策略（§13）。tenant_id NULL=平台默认；rules jsonb；is_active 默认 false。
model ModerationPolicy {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String?  @map("tenant_id") @db.Uuid
  name      String?  @db.VarChar(128)
  rules     Json?    @db.JsonB
  isActive  Boolean  @default(false) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("moderation_policy")
  @@schema("safety")
}

// 审核日志（§13）。direction input|output；result 默认 not_checked（区分"没查过"vs"查过通过"）；
// request_id 为跨库关联键（reqlog ↔ usage_event ↔ moderation_log，§17）。
model ModerationLog {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String?  @map("tenant_id") @db.Uuid
  requestId String?  @map("request_id") @db.VarChar(128)
  direction String   @db.VarChar(16)
  result    String   @default("not_checked") @db.VarChar(32)
  detail    Json?    @db.JsonB
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([requestId], map: "idx_moderation_log_request")
  @@map("moderation_log")
  @@schema("safety")
}
