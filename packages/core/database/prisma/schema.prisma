// ═══════════════════════════════════════════════════════════════
// commerce 计量内核（§8）。usage_event/_pool 按月 RANGE 分区、append-only RAISE 触发器、
// consume 全序锁/惰性归零、CHECK 均为非 Prisma DDL / 服务逻辑 → 落 B15 + 延后服务改写。
// ═══════════════════════════════════════════════════════════════

// 实时余量 SoT（§8.2）。瀑布全序 priority,billing_kind,effective_at,id；软退役不硬删。
model QuotaPool {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId        String    @map("workspace_id") @db.Uuid
  subscriptionId     String?   @map("subscription_id") @db.Uuid
  productId          String    @map("product_id") @db.Uuid
  metricKey          String    @map("metric_key") @db.VarChar(64)
  quotaLimit         BigInt    @map("quota_limit")
  quotaUsed          BigInt    @default(0) @map("quota_used")
  priority           Int       @default(100)
  billingKind        String    @map("billing_kind") @db.VarChar(32)
  poolSource         String    @default("subscription") @map("pool_source") @db.VarChar(32)
  resetPeriod        String    @default("none") @map("reset_period") @db.VarChar(16)
  currentPeriodStart DateTime? @map("current_period_start") @db.Timestamptz(6)
  status             String    @default("active") @db.VarChar(32)
  retiredAt          DateTime? @map("retired_at") @db.Timestamptz(6)
  grantedBy          String?   @map("granted_by") @db.Uuid
  grantReason        String?   @map("grant_reason") @db.VarChar(256)
  effectiveAt        DateTime  @default(now()) @map("effective_at") @db.Timestamptz(6)
  expiresAt          DateTime? @map("expires_at") @db.Timestamptz(6)
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  subscription TenantSubscription?   @relation(fields: [subscriptionId], references: [id])
  usagePools   TenantUsageEventPool[]
  resets       QuotaPoolReset[]

  @@index([workspaceId, productId, metricKey, priority], map: "idx_quota_pool_route")
  @@map("quota_pool")
  @@schema("commerce")
}

// 用量事件头（§8.4）。分区键 created_at 进复合 PK（分区/append-only 触发器 B15）。
model TenantUsageEvent {
  id              String   @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId     String   @map("workspace_id") @db.Uuid
  productId       String   @map("product_id") @db.Uuid
  metricKey       String   @map("metric_key") @db.VarChar(64)
  totalAmount     BigInt   @map("total_amount")
  requestedAmount BigInt?  @map("requested_amount")
  idempotencyKey  String?  @map("idempotency_key") @db.VarChar(128)
  requestId       String?  @map("request_id") @db.VarChar(128)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  pools TenantUsageEventPool[]

  @@id([id, createdAt])
  @@index([workspaceId, productId, metricKey], map: "idx_tue_route")
  @@map("tenant_usage_event")
  @@schema("commerce")
}

// 用量明细（§8.4），每命中池一行；复合 FK 指向头 + quota_pool。
model TenantUsageEventPool {
  eventId        String   @map("event_id") @db.Uuid
  eventCreatedAt DateTime @map("event_created_at") @db.Timestamptz(6)
  quotaPoolId    String   @map("quota_pool_id") @db.Uuid
  took           BigInt

  event TenantUsageEvent @relation(fields: [eventId, eventCreatedAt], references: [id, createdAt])
  pool  QuotaPool        @relation(fields: [quotaPoolId], references: [id])

  @@id([eventId, eventCreatedAt, quotaPoolId])
  @@map("tenant_usage_event_pool")
  @@schema("commerce")
}

// 幂等权威（§8.5，非分区，全局唯一 key）；重放直接返回 consumed/per_pool。
model UsageIdempotency {
  idempotencyKey String    @id @map("idempotency_key") @db.VarChar(128)
  eventId        String?   @map("event_id") @db.Uuid
  eventCreatedAt DateTime? @map("event_created_at") @db.Timestamptz(6)
  consumed       BigInt?
  perPool        Json?     @map("per_pool") @db.JsonB
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("usage_idempotency")
  @@schema("commerce")
}

// 归零审计（§8.6）：使合法归零与真实漂移可区分。
model QuotaPoolReset {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  poolId          String    @map("pool_id") @db.Uuid
  periodStart     DateTime? @map("period_start") @db.Timestamptz(6)
  usedBeforeReset BigInt    @map("used_before_reset")
  resetAt         DateTime  @default(now()) @map("reset_at") @db.Timestamptz(6)

  pool QuotaPool @relation(fields: [poolId], references: [id])

  @@map("quota_pool_reset")
  @@schema("commerce")
}

// 用量对账小时层（§8.7）。实时读 quota_pool，本表仅周期对账；天/月降采样另表。
