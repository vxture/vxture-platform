// ════════════════════════════════════════════════════════════════════════════
// ⚠️ SUPERSEDED — 非权威（2026-07-04）。平台库结构的单一权威已迁至手写 SQL DDL：
//     deploy/database/ddl/  (+ deploy/database/ddl-modelruntime/)。决策见 data_platform_320 §0–§3。
//   本文件为旧 8-schema 快照，仅保留供 `prisma db pull` 类型生成；**禁止**手编当权威、
//   禁止 `prisma db push`。生产切换后由 db pull 从新库重生成。
// ════════════════════════════════════════════════════════════════════════════
// @package @vxture/core-database
// @layer  Infrastructure
// @category Database DDL — 平台手动维护 schema 的 Prisma 统一管理
//
// 覆盖范围（7 个 schema；tenant 域已退役，并入 identity）：
//   identity — 16 张：users / identities / user_credential /
//                      tenant / workspaces / tenant_membership / workspace_memberships /
//                      invitation / auth_session / refresh_token / user_verification /
//                      password_reset_token / login_attempt / oauth_provider / oauth_state /
//                      audit_event
//   iam      —  5 张：role / permission / role_permission / oidc_client / signing_key
//   product  —  7 张：agent / agent_feature / feature / plan /
//                      plan_agent / plan_feature / plan_price
//   commerce — 15 张：tenant_invoice / tenant_invoice_item / tenant_invoice_receipt /
//                      tenant_payment / tenant_refund / tenant_subscription /
//                      tenant_subscription_quota / tenant_usage_event / tenant_usage_summary /
//                      tenant_subscription_history / tenant_subscription_override /
//                      tenant_transaction / tenant_credit /
//                      tenant_billing_address / tenant_payment_method
//   model    —  5 张：provider / model / model_grant / model_price_rule / model_policy
//   admin    — 16 张：operator_account / operator_credential / operator_mfa /
//                      operator_webauthn_credential / operator_recovery_code /
//                      operator_verification / operator_login_attempt / operator_refresh_token /
//                      operator_role / operator_permission / operator_role_permission /
//                      setting / governance_record / feature_flag / announcement / maintenance
//                      （原 ops schema，2026-07-02 改名 admin；表名 operator_* 前缀保留）
//   support  —  4 张：ticket / ticket_event / audit_log / notification_log
//
// 注：commerce 计量表（quota / usage_event / usage_summary）已纳入统一建模，
//     为 model-platform 单一权威源；服务侧不再独立迁移这些表。

generator client {
  provider        = "prisma-client-js"
  output          = "../node_modules/.prisma/core-database-client"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["identity", "iam", "product", "commerce", "model", "safety", "admin", "support"]
}

// ═══════════════════════════════════════════════════════════════
// schema: identity  （统一身份权威；org/workspace/membership 并入，tenant 域退役）
// 设计依据（字段级权威）：docs/design/platform-data-architecture-schema.md §4 identity 域
// ═══════════════════════════════════════════════════════════════

// 用户（终端用户 / tenant realm）。三标识 account/email/phone 各自唯一；phone 为强制全局锚点（NOT NULL + 已验证）。
model User {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userNo          BigInt    @unique(map: "users_user_no_key") @default(dbgenerated("nextval('identity.user_no_seq'::regclass)")) @map("user_no") @db.BigInt
  account         String    @unique(map: "users_account_key") @db.VarChar(64)
  email           String?   @unique(map: "users_email_key") @db.VarChar(128)
  emailVerifiedAt DateTime? @map("email_verified_at") @db.Timestamptz(6)
  phone           String    @unique(map: "users_phone_key") @db.VarChar(32)
  phoneVerifiedAt DateTime  @map("phone_verified_at") @db.Timestamptz(6)
  accountChangedAt DateTime? @map("account_changed_at") @db.Timestamptz(6)
  status          String    @default("active") @db.VarChar(32)
  levelNo         Int       @default(1) @map("level_no")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz(6)

  credential            UserCredential?
  identities            Identity[]
  avatar                UserAvatar?
  ownedTenants    Tenant[]        @relation("TenantOwner")
  tenantMemberships        TenantMembership[]
  workspaceMemberships  WorkspaceMembership[]
  profile               UserProfile?
  points                UserPoints?
  pointsLedger          UserPointsLedger[]
  taskProgress          UserTaskProgress[]

  @@index([userNo], map: "idx_users_user_no")
  @@index([email], map: "idx_users_email")
  @@index([phone], map: "idx_users_phone")
  @@index([status], map: "idx_users_status")
  @@index([levelNo], map: "idx_users_level_no")
  @@index([deletedAt], map: "idx_users_deleted_at")
  @@map("users")
  @@schema("identity")
}

// 自定义/导入头像字节（docs/design/identity-platform-account.md §2 D-1）。仅承载真实头像
// （用户上传 / 三方首创导入）；默认头像是前端内联资产（D-2），不入库。hash =
// 内容 sha256，作 URL 版本段 + ETag，并冗余到 users.avatar_hash 供 claim 轻读。
model UserAvatar {
  userId      String   @id @map("user_id") @db.Uuid
  data        Bytes
  contentType String   @map("content_type") @db.VarChar(32)
  hash        String   @db.VarChar(64)
  source      String   @db.VarChar(16)
  updatedAt   DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_avatar")
  @@schema("identity")
}

// 1:1 展示/本地化资料（platform-data-architecture-schema.md §4.1.2）。核心鉴权表 users 只留
// 认证列；display_name/avatar/bio/language/timezone MOVE 至此，资料编辑接口无从触及安全列。
model UserProfile {
  userId      String   @id @map("user_id") @db.Uuid
  displayName String?  @map("display_name") @db.VarChar(96)
  avatarUrl   String?  @map("avatar_url") @db.VarChar(512)
  avatarHash  String?  @map("avatar_hash") @db.VarChar(64)
  bio         String?  @db.VarChar(512)
  language    String?  @db.VarChar(16)
  timezone    String?  @db.VarChar(64)
  extra       Json?    @db.JsonB
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profile")
  @@schema("identity")
}

// 成长子域（§6）：等级 → 建组织数上限（配置表，占位 seed 5 档）。
model UserLevelPolicy {
  levelNo           Int     @id @map("level_no")
  maxOwnedOrgTenant Int     @map("max_owned_org_tenant")
  description       String? @db.VarChar(128)

  threshold UserLevelThreshold?

  @@map("user_level_policy")
  @@schema("identity")
}

// 成长子域（§6）：积分 → 等级单调阈值（配置表）。min_points 唯一→保可比单调。
model UserLevelThreshold {
  levelNo   Int    @id @map("level_no")
  minPoints BigInt @map("min_points")

  policy UserLevelPolicy @relation(fields: [levelNo], references: [levelNo])

  @@unique([minPoints], map: "uidx_user_level_threshold_min_points")
  @@map("user_level_threshold")
  @@schema("identity")
}

// 成长子域（§6）：当前积分余额单行汇总（避免每次 SUM 流水）。
model UserPoints {
  userId      String   @id @map("user_id") @db.Uuid
  totalPoints BigInt   @default(0) @map("total_points")
  updatedAt   DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_points")
  @@schema("identity")
}

// 成长子域（§6）：完整积分流水。points_delta 允许负数（消耗）；余额一致性由应用层同事务维护。
model UserPointsLedger {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  sourceType   String   @map("source_type") @db.VarChar(64)
  sourceRefId  String?  @map("source_ref_id") @db.VarChar(128)
  pointsDelta  BigInt   @map("points_delta")
  balanceAfter BigInt   @map("balance_after")
  remark       String?  @db.VarChar(512)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt], map: "idx_user_points_ledger_user")
  @@map("user_points_ledger")
  @@schema("identity")
}

// 成长子域（§6）：多步累计当前状态（连续签到/任务完成度）。每 (user, progress_type) 单行。
model UserTaskProgress {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  progressType  String    @map("progress_type") @db.VarChar(64)
  currentValue  BigInt    @default(0) @map("current_value")
  targetValue   BigInt?   @map("target_value")
  lastUpdatedAt DateTime  @default(now()) @map("last_updated_at") @db.Timestamptz(6)
  resetAt       DateTime? @map("reset_at") @db.Timestamptz(6)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, progressType], map: "uidx_user_task_progress_user_type")
  @@map("user_task_progress")
  @@schema("identity")
}

// 凭据：Argon2id 全量（无 bcrypt 债）。phone-code-only 用户 password_hash 可空。MFA 列留待阶段二。
model UserCredential {
  userId              String    @id @map("user_id") @db.Uuid
  passwordHash        String?   @map("password_hash") @db.VarChar(255)
  passwordChangedAt   DateTime? @map("password_changed_at") @db.Timestamptz(6)
  forcePasswordChange Boolean   @default(false) @map("force_password_change")
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_credential")
  @@schema("identity")
}

// 联邦身份绑定（Google/飞书/钉钉…）。不按 email 自动并号（platform-data-architecture-schema.md §4 identity）。
model Identity {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  provider        String   @db.VarChar(32)
  providerSubject String   @map("provider_subject") @db.VarChar(255)
  metadata        Json?    @db.JsonB
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerSubject], map: "identities_provider_subject_key")
  @@unique([userId, provider], map: "identities_user_provider_key")
  @@index([userId], map: "idx_identities_user_id")
  @@index([provider], map: "idx_identities_provider")
  @@map("identities")
  @@schema("identity")
}

// 组织：顶层归属单元。个人 = type=personal（注册即建 default workspace + owner membership，统一模型 §5.3）。
model Tenant {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String    @db.VarChar(128)
  type         String    @db.VarChar(16)
  ownerUserId  String    @map("owner_user_id") @db.Uuid
  status       String    @default("active") @db.VarChar(32)
  verificationStatus String  @default("unverified") @map("verification_status") @db.VarChar(32)
  verificationType   String? @map("verification_type") @db.VarChar(32)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)

  owner       User                  @relation("TenantOwner", fields: [ownerUserId], references: [id])
  workspaces  Workspace[]
  memberships TenantMembership[]
  invitations Invitation[]
  profile     TenantProfile?

  @@index([ownerUserId], map: "idx_tenant_owner_user_id")
  @@index([type], map: "idx_tenant_type")
  @@index([status], map: "idx_tenant_status")
  @@index([deletedAt], map: "idx_tenant_deleted_at")
  @@map("tenant")
  @@schema("identity")
}

// 租户（组织）资料：与核心 organizations 1:1 解耦，承载展示/联系/本地化字段
// （console 信息 spec §3.2/3.3/3.6）。logo 二进制内联（小图，按 logo_hash 版本化）。
model TenantProfile {
  tenantId     String   @id @map("tenant_id") @db.Uuid
  logoData           Bytes?   @map("logo_data")
  logoContentType    String?  @map("logo_content_type") @db.VarChar(32)
  logoHash           String?  @map("logo_hash") @db.VarChar(64)
  description        String?  @db.Text
  industry           String?  @db.VarChar(64)
  scale              String?  @db.VarChar(32)
  website            String?  @db.VarChar(255)
  contactName        String?  @map("contact_name") @db.VarChar(96)
  contactRole        String?  @map("contact_role") @db.VarChar(96)
  contactEmail       String?  @map("contact_email") @db.VarChar(128)
  contactPhone       String?  @map("contact_phone") @db.VarChar(32)
  countryCode        String?  @map("country_code") @db.VarChar(8)
  address            String?  @db.VarChar(255)
  postalCode         String?  @map("postal_code") @db.VarChar(16)
  isBillingRecipient Boolean  @default(false) @map("is_billing_recipient")
  timezone           String?  @db.VarChar(64)
  language           String?  @db.VarChar(16)
  currency           String?  @db.VarChar(8)
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_profile")
  @@schema("identity")
}

// 工作空间：Org 1:N。注册即建 1 个 default（每 org 仅一 default，由 migration 部分唯一索引 + 应用层共同保证）。
model Workspace {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId String    @map("tenant_id") @db.Uuid
  name           String    @db.VarChar(128)
  isDefault      Boolean   @default(false) @map("is_default")
  description    String?   @db.Text
  icon           String?   @db.VarChar(64)
  status         String    @default("active") @db.VarChar(16)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(6)

  tenant Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  memberships  WorkspaceMembership[]
  invitations  Invitation[]

  @@index([tenantId], map: "idx_workspaces_tenant_id")
  @@index([deletedAt], map: "idx_workspaces_deleted_at")
  @@map("workspaces")
  @@schema("identity")
}

// org 级成员与治理角色。role 取值引用 iam.role.code（scope=org）；不建跨 schema FK，按 code 解析。
model TenantMembership {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId String   @map("tenant_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  role           String   @default("member") @db.VarChar(32)
  status         String   @default("active") @db.VarChar(32)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id])

  @@unique([tenantId, userId], map: "tenant_membership_tenant_user_key")
  @@index([userId], map: "idx_tenant_membership_user_id")
  @@index([role], map: "idx_tenant_membership_role")
  @@index([status], map: "idx_tenant_membership_status")
  @@map("tenant_membership")
  @@schema("identity")
}

// workspace 级成员与治理角色。role 引用 iam.role.code（scope=workspace）。当前淡化 workspace（默认 default）。
model WorkspaceMembership {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  role        String   @default("member") @db.VarChar(32)
  status      String   @default("active") @db.VarChar(32)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id])

  @@unique([workspaceId, userId], map: "workspace_memberships_ws_user_key")
  @@index([userId], map: "idx_workspace_memberships_user_id")
  @@index([role], map: "idx_workspace_memberships_role")
  @@index([status], map: "idx_workspace_memberships_status")
  @@map("workspace_memberships")
  @@schema("identity")
}

// 成员邀请（org / workspace）。§13.4 邀成员闭环。
model Invitation {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  scope          String    @db.VarChar(16)
  tenantId String?   @map("tenant_id") @db.Uuid
  workspaceId    String?   @map("workspace_id") @db.Uuid
  targetType     String    @map("target_type") @db.VarChar(16)
  target         String    @db.VarChar(128)
  role           String    @db.VarChar(32)
  status         String    @default("pending") @db.VarChar(32)
  tokenHash      String    @unique(map: "invitation_token_hash_key") @map("token_hash") @db.VarChar(64)
  expiresAt      DateTime  @map("expires_at") @db.Timestamptz(6)
  acceptedAt     DateTime? @map("accepted_at") @db.Timestamptz(6)
  createdBy      String    @map("created_by") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  tenant Tenant? @relation(fields: [tenantId], references: [id])
  workspace    Workspace?    @relation(fields: [workspaceId], references: [id])

  @@index([tenantId], map: "idx_invitation_tenant_id")
  @@index([workspaceId], map: "idx_invitation_workspace_id")
  @@index([status], map: "idx_invitation_status")
  @@index([expiresAt], map: "idx_invitation_expires_at")
  @@map("invitation")
  @@schema("identity")
}

// 中心会话持久镜像（Redis 为主）。realm 区分 customer/workforce。loose user_id（无跨实体 FK）。
model AuthSession {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sid          String    @unique(map: "auth_session_sid_key") @db.VarChar(64)
  userId       String    @map("user_id") @db.Uuid
  realm        String    @db.VarChar(16)
  authMethod   String    @map("auth_method") @db.VarChar(32)
  ipAddress    String?   @map("ip_address") @db.VarChar(64)
  userAgent    String?   @map("user_agent") @db.VarChar(512)
  status       String    @default("active") @db.VarChar(16)
  lastActiveAt DateTime  @default(now()) @map("last_active_at") @db.Timestamptz(6)
  expiresAt    DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt    DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([userId], map: "idx_auth_session_user_id")
  @@index([expiresAt], map: "idx_auth_session_expires_at")
  @@map("auth_session")
  @@schema("identity")
}

// opaque refresh token：服务端存储、轮换、重放检测（§6.3）。token_hash 唯一；rotated_from 串起轮换链。
model RefreshToken {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  sessionId   String    @map("session_id") @db.Uuid
  clientId    String    @map("client_id") @db.VarChar(64)
  tokenHash   String    @unique(map: "refresh_token_token_hash_key") @map("token_hash") @db.VarChar(64)
  rotatedFrom String?   @map("rotated_from") @db.Uuid
  status      String    @default("active") @db.VarChar(16)
  expiresAt   DateTime  @map("expires_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([userId], map: "idx_refresh_token_user_id")
  @@index([sessionId], map: "idx_refresh_token_session_id")
  @@index([expiresAt], map: "idx_refresh_token_expires_at")
  @@map("refresh_token")
  @@schema("identity")
}

// 邮箱/手机验证码，append-only。
model UserVerification {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String?   @map("user_id") @db.Uuid
  targetType   String    @map("target_type") @db.VarChar(16)
  target       String    @db.VarChar(128)
  purpose      String    @db.VarChar(32)
  codeHash     String    @map("code_hash") @db.VarChar(64)
  attemptCount Int       @default(0) @map("attempt_count")
  expiresAt    DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt       DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([userId], map: "idx_user_verification_user_id")
  @@index([target, expiresAt], map: "idx_user_verification_target_expires")
  @@map("user_verification")
  @@schema("identity")
}

// 密码重置令牌，append-only。loose user_id。
model PasswordResetToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique(map: "password_reset_token_token_hash_key") @map("token_hash") @db.VarChar(64)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([userId], map: "idx_password_reset_token_user_id")
  @@index([expiresAt], map: "idx_password_reset_token_expires_at")
  @@map("password_reset_token")
  @@schema("identity")
}

// 登录尝试记录，风控/限速，append-only。
model LoginAttempt {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String?  @map("user_id") @db.Uuid
  identifier  String   @db.VarChar(128)
  authMethod  String   @default("password") @map("auth_method") @db.VarChar(32)
  result      String   @db.VarChar(32)
  ipAddress   String   @map("ip_address") @db.VarChar(64)
  countryCode String?  @map("country_code") @db.Char(2)
  userAgent   String?  @map("user_agent") @db.VarChar(512)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([identifier, createdAt(sort: Desc)], map: "idx_login_attempt_identifier_created")
  @@index([ipAddress, createdAt(sort: Desc)], map: "idx_login_attempt_ip_created")
  @@index([userId], map: "idx_login_attempt_user_id")
  @@map("login_attempt")
  @@schema("identity")
}

// 入站联邦 provider 配置（broker）。表驱动启用，无需改 env/重部署。
model OauthProvider {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code           String   @unique(map: "oauth_provider_code_key") @db.VarChar(64)
  name           String   @db.VarChar(64)
  clientId       String?  @map("client_id") @db.VarChar(255)
  clientSecret   String?  @map("client_secret") @db.VarChar(255)
  scope          String?  @db.VarChar(512)
  authUrl        String?  @map("auth_url") @db.VarChar(512)
  tokenUrl       String?  @map("token_url") @db.VarChar(512)
  accountInfoUrl String?  @map("account_info_url") @db.VarChar(512)
  redirectUri    String?  @map("redirect_uri") @db.VarChar(512)
  isEnabled      Boolean  @default(true) @map("is_enabled")
  sort           Int      @default(999)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@index([isEnabled], map: "idx_oauth_provider_is_enabled")
  @@index([sort], map: "idx_oauth_provider_sort")
  @@map("oauth_provider")
  @@schema("identity")
}

// OAuth 授权请求状态，append-only。
model OauthState {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  providerCode String   @map("provider_code") @db.VarChar(64)
  state        String   @unique(map: "oauth_state_state_key") @db.VarChar(128)
  redirectUri  String   @map("redirect_uri") @db.VarChar(512)
  codeVerifier String?  @map("code_verifier") @db.VarChar(128)
  nonce        String?  @db.VarChar(128)
  ipAddress    String?  @map("ip_address") @db.VarChar(64)
  expiresAt    DateTime @map("expires_at") @db.Timestamptz(6)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([expiresAt], map: "idx_oauth_state_expires_at")
  @@index([providerCode], map: "idx_oauth_state_provider_code")
  @@map("oauth_state")
  @@schema("identity")
}

// 审计事件最小落地（§10）：UserLogin/Logout/IdentityBind/RoleChange/TokenIssue（+失败）。append-only。
model AuditEvent {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventType      String   @map("event_type") @db.VarChar(32)
  userId         String?  @map("user_id") @db.Uuid
  tenantId String?  @map("tenant_id") @db.Uuid
  workspaceId    String?  @map("workspace_id") @db.Uuid
  result         String   @db.VarChar(16)
  ipAddress      String?  @map("ip_address") @db.VarChar(64)
  metadata       Json?    @db.JsonB
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([eventType, createdAt(sort: Desc)], map: "idx_audit_event_type_created")
  @@index([userId], map: "idx_audit_event_user_id")
  @@index([tenantId], map: "idx_audit_event_tenant_id")
  @@map("audit_event")
  @@schema("identity")
}

// ═══════════════════════════════════════════════════════════════
// schema: iam  （治理 RBAC 全局目录 + oidc_client + 签名密钥；workforce realm 复用 admin.operator_account）
// 设计依据（字段级权威）：docs/design/platform-data-architecture-schema.md §5 iam 域
// ═══════════════════════════════════════════════════════════════

// 治理角色全局目录（非 per-tenant）。scope=org|workspace；code 在 scope 内唯一。
model Role {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code      String   @db.VarChar(64)
  scope     String   @db.VarChar(16)
  name      String   @db.VarChar(128)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  rolePermissions RolePermission[]

  @@unique([scope, code], map: "role_scope_code_key")
  @@index([scope], map: "idx_role_scope")
  @@map("role")
  @@schema("iam")
}

// 权限目录。code 全局唯一。
model Permission {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String   @unique(map: "permission_code_key") @db.VarChar(128)
  description String?  @db.VarChar(512)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  rolePermissions RolePermission[]

  @@map("permission")
  @@schema("iam")
}

// 角色→权限关联，复合主键。
model RolePermission {
  roleId       String   @map("role_id") @db.Uuid
  permissionId String   @map("permission_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId], map: "idx_role_permission_permission_id")
  @@map("role_permission")
  @@schema("iam")
}

// OIDC 出站客户端注册（应用→平台）。身份接入方 = oidc_client，≠ product.application ≠ agent（§9 红线）。
model OidcClient {
  id                     String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId               String   @unique(map: "oidc_client_client_id_key") @map("client_id") @db.VarChar(64)
  name                   String   @db.VarChar(128)
  displayName            String?  @map("display_name") @db.VarChar(128)
  logoUrl                String?  @map("logo_url") @db.VarChar(512)
  realm                  String   @default("customer") @db.VarChar(16)
  clientSecretHash       String?  @map("client_secret_hash") @db.VarChar(255)
  redirectUris           String[] @map("redirect_uris")
  postLogoutRedirectUris String[] @map("post_logout_redirect_uris")
  backChannelLogoutUri   String?  @map("back_channel_logout_uri") @db.VarChar(512)
  allowedScopes          String[] @map("allowed_scopes")
  accessTokenTtl         Int      @default(900) @map("access_token_ttl")
  refreshTokenTtl        Int      @default(2592000) @map("refresh_token_ttl")
  pkceRequired           Boolean  @default(true) @map("pkce_required")
  isEnabled              Boolean  @default(true) @map("is_enabled")
  productId              String?  @map("product_id") @db.Uuid
  releaseChannel         String   @default("stable") @map("release_channel") @db.VarChar(32)
  sloParticipation       String   @default("back_channel") @map("slo_participation") @db.VarChar(32)
  createdAt              DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@index([realm], map: "idx_oidc_client_realm")
  @@index([isEnabled], map: "idx_oidc_client_is_enabled")
  @@map("oidc_client")
  @@schema("iam")
}

// 签名公钥/元数据（私钥不落库，进 secret manager）。
model SigningKey {
  kid         String    @id @db.VarChar(64)
  algorithm   String    @default("RS256") @db.VarChar(16)
  publicJwk   Json      @map("public_jwk") @db.JsonB
  status      String    @default("next") @db.VarChar(16)
  activatedAt DateTime? @map("activated_at") @db.Timestamptz(6)
  retiringAt  DateTime? @map("retiring_at") @db.Timestamptz(6)
  retiredAt   DateTime? @map("retired_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([status], map: "idx_signing_key_status")
  @@map("signing_key")
  @@schema("iam")
}

// ═══════════════════════════════════════════════════════════════
// schema: product（统一 product + 版本化 plan + product_webhook；§7）
// 设计依据：docs/design/platform-data-architecture-schema.md §7
// GIN 索引(tags/capability_keys)、CHECK 约束、锁定/priority 触发器为非 Prisma DDL，落 B15 baseline。
// ═══════════════════════════════════════════════════════════════

// 产品品类树形字典（§7.4）。smallint PK 为 uuid 规范的刻意例外（小型策展字典、人读、可排序）。
model ProductCategory {
  id        Int      @id @db.SmallInt
  parentId  Int?     @map("parent_id") @db.SmallInt
  code      String   @unique(map: "uidx_product_category_code") @db.VarChar(32)
  name      String   @db.VarChar(64)
  sort      Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  parent   ProductCategory?  @relation("ProductCategoryTree", fields: [parentId], references: [id])
  children ProductCategory[] @relation("ProductCategoryTree")
  products Product[]

  @@index([parentId], map: "idx_product_category_parent")
  @@map("product_category")
  @@schema("product")
}

// 统一产品目录（合并 agent + application，§7.2）。名称走 product_i18n；home_url/webhook → product_webhook。
model Product {
  id                     String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productCode            String    @unique(map: "uidx_product_code") @map("product_code") @db.VarChar(64)
  productType            String    @map("product_type") @db.VarChar(32)
  categoryId             Int?      @map("category_id") @db.SmallInt
  description            String?   @db.Text
  capabilityKeys         String[]  @default([]) @map("capability_keys")
  tags                   String[]  @default([])
  standaloneSubscribable Boolean   @default(true) @map("standalone_subscribable")
  iconUrl                String?   @map("icon_url") @db.VarChar(512)
  sort                   Int       @default(0)
  config                 Json?     @db.JsonB
  releaseVersion         String?   @map("release_version") @db.VarChar(32)
  buildNumber            String?   @map("build_number") @db.VarChar(64)
  releasedAt             DateTime? @map("released_at") @db.Timestamptz(6)
  status                 String    @default("active") @db.VarChar(32)
  createdBy              String?   @map("created_by") @db.Uuid
  updatedBy              String?   @map("updated_by") @db.Uuid
  createdAt              DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt              DateTime? @map("deleted_at") @db.Timestamptz(6)

  category       ProductCategory?      @relation(fields: [categoryId], references: [id])
  metrics        ProductMetric[]
  i18n           ProductI18n[]
  planComponents PlanComponent[]
  webhook        ProductWebhook?
  launchStatuses ProductLaunchStatus[]

  @@index([categoryId], map: "idx_product_category")
  @@index([status], map: "idx_product_status")
  @@index([deletedAt], map: "idx_product_deleted_at")
  @@map("product")
  @@schema("product")
}

// 产品计量口径（§7.3）。merge_strategy=max|union（能力型）| pool（消耗型，配额池）；consume_mode 仅 pool 必填。
model ProductMetric {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId     String   @map("product_id") @db.Uuid
  metricKey     String   @map("metric_key") @db.VarChar(64)
  mergeStrategy String   @map("merge_strategy") @db.VarChar(16)
  consumeMode   String?  @map("consume_mode") @db.VarChar(16)
  metricUnit    String?  @map("metric_unit") @db.VarChar(32)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  product Product @relation(fields: [productId], references: [id])

  @@unique([productId, metricKey], map: "uidx_product_metric_product_key")
  @@map("product_metric")
  @@schema("product")
}

// 产品多语言（§7.5，双槽位 name/nick，无默认兜底，全 locale 覆盖由 launch_checklist 收口）。
model ProductI18n {
  productId   String   @map("product_id") @db.Uuid
  locale      String   @db.VarChar(16)
  productName String   @map("product_name") @db.VarChar(128)
  productNick String   @map("product_nick") @db.VarChar(128)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  product Product @relation(fields: [productId], references: [id])

  @@id([productId, locale])
  @@map("product_i18n")
  @@schema("product")
}

// 方案壳（§7.6）。current_version_id 指向当前对外销售版本。
model Plan {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  planCode         String    @unique(map: "uidx_plan_code") @map("plan_code") @db.VarChar(64)
  planName         String    @map("plan_name") @db.VarChar(128)
  description      String?   @db.Text
  billingCycle     String    @default("monthly") @map("billing_cycle") @db.VarChar(32)
  currentVersionId String?   @map("current_version_id") @db.Uuid
  isPublic         Boolean   @default(true) @map("is_public")
  status           String    @default("active") @db.VarChar(32)
  createdBy        String?   @map("created_by") @db.Uuid
  updatedBy        String?   @map("updated_by") @db.Uuid
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz(6)

  versions       PlanVersion[] @relation("PlanVersions")
  currentVersion PlanVersion?  @relation("PlanCurrentVersion", fields: [currentVersionId], references: [id])

  @@map("plan")
  @@schema("product")
}

// 版本容器（§7.6）。draft 可编辑其 plan_component；published 后冻结（价格/版本号/组件不可改），
// 单向 draft→published 不可逆，改动只能开新草稿版本。无 components JSONB（plan_component 唯一 SoT）。
model PlanVersion {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  planId      String    @map("plan_id") @db.Uuid
  versionNo   Int       @map("version_no")
  price       Decimal   @db.Decimal(18, 6)
  currency    String    @default("CNY") @db.VarChar(16)
  status      String    @default("draft") @db.VarChar(16) // draft | published（单向，不可逆）
  publishedAt DateTime? @map("published_at") @db.Timestamptz(6)
  createdBy   String?   @map("created_by") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  plan       Plan            @relation("PlanVersions", fields: [planId], references: [id])
  currentOf  Plan[]          @relation("PlanCurrentVersion")
  components PlanComponent[]

  @@unique([planId, versionNo], map: "uidx_plan_version_plan_no")
  @@map("plan_version")
  @@schema("product")
}

// 组件：唯一 SoT（§7.6，替代 plan_agent/plan_feature）。挂 plan_version，一档一产品一行。
model PlanComponent {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  planVersionId String   @map("plan_version_id") @db.Uuid
  productId     String   @map("product_id") @db.Uuid
  tier          String   @db.VarChar(32)
  enabled       Boolean  @default(true)
  billingKind   String   @map("billing_kind") @db.VarChar(32)
  priority      Int      @default(100)
  features      String[] @default([])
  quota         Json?    @db.JsonB
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  planVersion PlanVersion @relation(fields: [planVersionId], references: [id])
  product     Product     @relation(fields: [productId], references: [id])

  @@unique([planVersionId, productId, tier], map: "uidx_plan_component_version_product_tier")
  @@index([planVersionId], map: "idx_plan_component_version")
  @@map("plan_component")
  @@schema("product")
}

// 平台自签 HMAC webhook（§7.7，承接 application.home_url/webhook_*，非 Provider Key，可入平台库）。
model ProductWebhook {
  productId        String   @id @map("product_id") @db.Uuid
  homeUrl          String?  @map("home_url") @db.VarChar(512)
  webhookUrl       String?  @map("webhook_url") @db.VarChar(512)
  webhookSecretRef String?  @map("webhook_secret_ref") @db.VarChar(128)
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_webhook")
  @@schema("product")
}

// 上架检查清单目录（§7.8，可配置项，新增项=INSERT 一行）。
model LaunchChecklistItem {
  itemCode    String   @id @map("item_code") @db.VarChar(64)
  itemName    String   @map("item_name") @db.VarChar(128)
  description String?  @db.VarChar(256)
  isRequired  Boolean  @default(true) @map("is_required")
  sort        Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  statuses ProductLaunchStatus[]

  @@map("launch_checklist_item")
  @@schema("product")
}

// 每 product 对每检查项的完成状态（§7.8）；上架资格由所有 is_required 项 is_satisfied 推导。
model ProductLaunchStatus {
  productId   String    @map("product_id") @db.Uuid
  itemCode    String    @map("item_code") @db.VarChar(64)
  isSatisfied Boolean   @default(false) @map("is_satisfied")
  checkedAt   DateTime? @map("checked_at") @db.Timestamptz(6)
  checkedBy   String?   @map("checked_by") @db.Uuid
  remark      String?   @db.VarChar(256)

  product Product             @relation(fields: [productId], references: [id])
  item    LaunchChecklistItem @relation(fields: [itemCode], references: [itemCode])

  @@id([productId, itemCode])
  @@map("product_launch_status")
  @@schema("product")
}

// ═══════════════════════════════════════════════════════════════
// schema: commerce（手动维护；quota/event/summary 由 gateway 管理）
// ═══════════════════════════════════════════════════════════════

// KYC 可配置门控（§6.3.2）。product_id NULL=平台基准值（非兜底），非 NULL=该产品策略（上架必填）。
// 跨 identity/commerce/product：product_id 为裸 UUID（无跨 schema FK，§18.1#3）。
model VerificationPolicy {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId           String?  @map("product_id") @db.Uuid
  tenantType          String   @map("tenant_type") @db.VarChar(32)
  requireVerification Boolean  @default(true) @map("require_verification")
  requiredType        String?  @map("required_type") @db.VarChar(32)
  isActive            Boolean  @default(true) @map("is_active")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("verification_policy")
  @@schema("commerce")
}

model TenantInvoice {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  billNo         String    @unique(map: "tenant_bill_bill_no_key") @map("bill_no") @db.VarChar(64)
  subscriptionId String?   @map("subscription_id") @db.Uuid
  billCycle      String    @map("bill_cycle") @db.VarChar(8)
  cycleStartDate DateTime  @map("cycle_start_date") @db.Date
  cycleEndDate   DateTime  @map("cycle_end_date") @db.Date
  totalAmount    Decimal   @default(0) @map("total_amount") @db.Decimal(12, 2)
  discountAmount Decimal?  @default(0) @map("discount_amount") @db.Decimal(12, 2)
  payableAmount  Decimal   @default(0) @map("payable_amount") @db.Decimal(12, 2)
  paidAmount     Decimal?  @default(0) @map("paid_amount") @db.Decimal(12, 2)
  currency       String?   @default("CNY") @db.VarChar(16)
  billStatus     String    @default("unpaid") @map("bill_status") @db.VarChar(32)
  billType       String?   @default("normal") @map("bill_type") @db.VarChar(32)
  paidAt         DateTime? @map("paid_at") @db.Timestamptz(6)
  paymentMethod  String?   @map("payment_method") @db.VarChar(64)
  transactionNo  String?   @map("transaction_no") @db.VarChar(128)
  operatorId     String?   @map("operator_id") @db.Uuid
  operateRemark  String?   @map("operate_remark") @db.Text
  createdBy      String?   @map("created_by") @db.Uuid
  updatedBy      String?   @map("updated_by") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(6)

  items    TenantInvoiceItem[]
  payments TenantPayment[]

  @@index([billCycle], map: "idx_ti_cycle")
  @@index([billNo], map: "idx_ti_invoice_no")
  @@index([billStatus], map: "idx_ti_status")
  @@index([deletedAt], map: "idx_ti_deleted_at")
  @@index([tenantId], map: "idx_ti_tenant_id")
  @@index([tenantId, billCycle], map: "idx_tenant_bill_tenant_cycle")
  @@map("tenant_invoice")
  @@schema("commerce")
