{
  "name": "@vxture/core-mail",
  "version": "1.0.0",
  "description": "Vxture platform — transactional mail sender (nodemailer wrapper)",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rimraf dist && tsup",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "nodemailer": "^6.10.1"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0"
  },
  "devDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.1.28",
    "@types/nodemailer": "^6.4.17",
    "reflect-metadata": "^0.2.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
