    "@nestjs/core": "^11.0.0",
    "@nestjs/axios": "^4.0.0",
    "@types/node": "^24.0.0",
    "@swc/core": "^1.10.0",
    "axios": "^1.18.1",
    "reflect-metadata": "^0.2.0",
    "rimraf": "^6.0.1",
    "rxjs": "^7.8.0",
