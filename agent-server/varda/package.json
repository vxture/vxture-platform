{
  "name": "@vxture/agent-server-varda",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/main.ts",
  "description": "Varda agent 私有后端 — CallerContext 校验、ToolRegistry、Tool Use Loop、会话持久化",
  "scripts": {
    "build": "pnpm -w build:backend-deps && esbuild src/main.ts --bundle --platform=node --format=cjs --target=node22 --outfile=dist/main.cjs --tsconfig=tsconfig.json --external:@nestjs/websockets/socket-module --external:@nestjs/microservices --external:@nestjs/microservices/microservices-module --external:@prisma/client --external:class-transformer/storage",
    "dev": "pnpm run build && node dist/main.cjs",
    "start": "node dist/main.cjs",
    "type-check": "tsc --noEmit",
    "prisma:generate": "prisma generate --schema=prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=prisma/schema.prisma",
    "lint": "eslint src",
    "lint:fix": "eslint --fix src"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@prisma/client": "^6.0.0",
    "@vxture/model-runtime-client": "workspace:*",
    "@vxture/core-auth": "workspace:*",
    "@vxture/core-config": "workspace:*",
    "@vxture/service-billing": "workspace:*",
    "@vxture/service-organization": "workspace:*",
    "@vxture/service-subscription": "workspace:*",
    "@vxture/service-ticket": "workspace:*",
    "@vxture/shared": "workspace:*",
    "class-transformer": "^0.5.1",
    "express": "^4.22.1",
    "reflect-metadata": "^0.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "esbuild": "^0.27.4",
    "prisma": "^6.0.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
