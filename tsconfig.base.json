{
  "compilerOptions": {
    // ─── 编译目标 ───────────────────────────────────────────────────────────
    "target": "ES2023",
    "lib": ["ES2023"], // 默认不含 DOM；前端包在本地覆盖为 ["DOM", "DOM.Iterable", "ES2023"]
    "module": "ESNext",
    "moduleResolution": "bundler",

    // ─── 严格模式（禁止任何包单独关闭） ────────────────────────────────────
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,

    // ─── 互操作 ─────────────────────────────────────────────────────────────
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "useDefineForClassFields": true,
    "resolveJsonModule": true,

    // ─── 工具链 ─────────────────────────────────────────────────────────────
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    // ─── 路径别名（monorepo 内部包统一入口） ────────────────────────────────
    "paths": {
      "@vxture/shared": ["./packages/shared/shared/src"],
      "@vxture/shared/*": ["./packages/shared/shared/src/*"],
      "@vxture/core-api": ["./packages/core/api/src"],
      "@vxture/core-api/*": ["./packages/core/api/src/*"],
      "@vxture/core-config": ["./packages/core/config/src"],
      "@vxture/core-config/*": ["./packages/core/config/src/*"],
      "@vxture/core-locale": ["./packages/core/locale/src"],
      "@vxture/core-locale/*": ["./packages/core/locale/src/*"],
      "@vxture/core-auth": ["./packages/core/auth/src"],
      "@vxture/core-auth/*": ["./packages/core/auth/src/*"],
      "@vxture/core-utils": ["./packages/core/utils/src"],
      "@vxture/core-utils/*": ["./packages/core/utils/src/*"],
      "@vxture/design-system": [
        "./packages/design/design-system/src/client.ts"
      ],
      "@vxture/design-system/tokens": [
        "./packages/design/design-system/src/tokens-entry.ts"
      ],
      "@vxture/design-system/types": [
        "./packages/design/design-system/src/types-entry.ts"
      ],
      "@vxture/design-system/server": [
        "./packages/design/design-system/src/server.ts"
      ],
      "@vxture/model-runtime-client": [
        "./packages/ai/model-runtime-client/src"
      ],
      "@vxture/model-runtime-client/*": [
        "./packages/ai/model-runtime-client/src/*"
      ],
      "@vxture/service-ticket": ["./services/support/ticket/src"],
      "@vxture/service-ticket/*": ["./services/support/ticket/src/*"],
      "@vxture/service-billing": ["./services/commerce/billing/src"],
      "@vxture/service-billing/*": ["./services/commerce/billing/src/*"],
      "@vxture/service-promotion": ["./services/commerce/promotion/src"],
      "@vxture/service-promotion/*": ["./services/commerce/promotion/src/*"],
      "@vxture/service-subscription": ["./services/commerce/subscription/src"],
      "@vxture/service-subscription/*": [
        "./services/commerce/subscription/src/*"
      ],
      "@vxture/service-organization": ["./services/identity/organization/src"],
      "@vxture/service-organization/*": [
        "./services/identity/organization/src/*"
      ],
      "@vxture/service-account": ["./services/identity/account/src"],
      "@vxture/service-account/*": ["./services/identity/account/src/*"],
      "@vxture/service-iam": ["./services/identity/iam/src"],
      "@vxture/service-iam/*": ["./services/identity/iam/src/*"],
      "@vxture/service-mail": ["./services/notification/mail/src"],
      "@vxture/service-mail/*": ["./services/notification/mail/src/*"],
      "@vxture/service-model-platform": ["./services/model/platform/src"],
      "@vxture/service-model-platform/*": ["./services/model/platform/src/*"],
      "@vxture/platform-browser": ["./packages/platform/browser/src"],
      "@vxture/platform-browser/*": ["./packages/platform/browser/src/*"]
    }
  },
  "include": [],
  "exclude": ["node_modules", "dist", "build"]
}
