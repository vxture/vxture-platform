{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "vxture",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.30.3",
  "description": "Vxture 大模型和智能体服务平台",
  "keywords": [
    "monorepo",
    "nextjs",
    "fastapi",
    "saas",
    "ai",
    "agents"
  ],
  "author": "vxture team",
  "scripts": {
    "// === 开发环境 ===": "",
    "dev": "pnpm --filter @vxture/website dev",
    "dev:console": "pnpm --filter @vxture/console dev",
    "dev:admin": "pnpm --filter @vxture/admin dev",
    "dev:panel": "pnpm --filter @vxture/dev-panel dev",
    "start:panel": "pnpm --filter @vxture/dev-panel start",
    "dev:gateway": "pnpm --filter @vxture/bff-gateway dev",
    "start:gateway": "pnpm --filter @vxture/bff-gateway start",
    "dev:website-bff": "pnpm --filter @vxture/bff-website dev",
    "dev:console-bff": "pnpm --filter @vxture/bff-console dev",
    "dev:admin-bff": "pnpm --filter @vxture/bff-admin dev",
    "dev:auth-bff": "pnpm --filter @vxture/bff-auth dev",
    "start:console-bff": "pnpm --filter @vxture/bff-console start",
    "dev:model-platform": "pnpm --filter @vxture/service-model-platform dev",
    "start:model-platform": "pnpm --filter @vxture/service-model-platform start",
    "start": "pnpm dev",
    "// === 构建和部署 ===": "",
    "build": "pnpm --filter @vxture/website build",
    "build:gateway": "pnpm --filter @vxture/bff-website build",
    "build:all": "pnpm --filter @vxture/shared build && pnpm --filter @vxture/core-* build && pnpm --filter @vxture/platform-* build && pnpm --filter @vxture/design-* build",
    "build:backend-deps": "pnpm run --if-present --filter @vxture/shared build && pnpm run --if-present --filter @vxture/core-* build",
    "build:frontend-deps": "pnpm run --if-present --filter @vxture/shared build && pnpm run --if-present --filter @vxture/core-* build && pnpm run --if-present --filter @vxture/platform-* build && pnpm run --if-present --filter @vxture/design-* build",
    "build:shared": "pnpm --filter @vxture/shared build",
    "build:core": "pnpm --filter @vxture/core-* build",
    "build:platform": "pnpm --filter @vxture/platform-* build",
    "build:design": "pnpm --filter @vxture/design-* build",
    "preview": "pnpm --filter @vxture/website preview",
    "// === 代码质量 ===": "",
    "lint": "pnpm --recursive --if-present lint",
    "lint:design": "node scripts/guardrails/check-design-system.mjs",
    "lint:data-design": "node scripts/guardrails/check-data-architecture.mjs",
    "lint:schema-residue": "node scripts/guardrails/check-schema-residue.mjs",
    "lint:i18n-keys": "node scripts/guardrails/check-i18n-keys.mjs",
    "lint:seed": "node scripts/guardrails/check-seed-idempotency.mjs",
    "lint:column-locks": "node scripts/guardrails/check-column-locks.mjs",
    "lint:catalog-domains": "node scripts/guardrails/check-catalog-domains.mjs",
    "lint:boundaries": "depcruise portals agent-studio agent-server business bff services packages/core packages/shared packages/ai packages/design packages/platform --config .depcruiserc.cjs",
    "lint:fix": "pnpm --recursive --if-present lint:fix",
    "type-check": "pnpm --filter @vxture/website type-check",
    "type-check:console": "pnpm --filter @vxture/console type-check",
    "type-check:console-bff": "pnpm --filter @vxture/bff-console type-check",
    "type-check:admin": "pnpm --filter @vxture/admin type-check",
    "type-check:admin-bff": "pnpm --filter @vxture/bff-admin type-check",
    "type-check:all": "pnpm --recursive type-check",
    "format": "prettier --write \"**/*.{js,ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,ts,tsx,json,md}\"",
    "// === 测试 ===": "",
    "test": "pnpm --recursive test",
    "test:watch": "pnpm --recursive test:watch",
    "test:coverage": "pnpm --recursive test:coverage",
    "// === 依赖管理 ===": "",
    "clean": "pnpm --recursive clean && rimraf node_modules",
    "clean:cache": "pnpm store prune && rimraf .turbo .next dist build",
    "reset": "pnpm clean && pnpm clean:cache && pnpm install",
    "update": "pnpm --recursive update",
    "check-deps": "pnpm audit && pnpm --recursive outdated",
    "// === 环境检查 ===": "",
    "check-env": "node -e \"console.log('Node:', process.version); console.log('PNPM:', process.env.npm_config_user_agent)\"",
    "audit:env": "node scripts/guardrails/audit-env.mjs",
    "health": "pnpm check-env && pnpm type-check && pnpm lint && pnpm lint:design",
    "// === 数据库操作 ===": "",
    "db:migrate": "pnpm --filter @vxture/bff-website db:migrate",
    "db:reset": "pnpm --filter @vxture/bff-website db:reset",
    "db:seed": "pnpm --filter @vxture/bff-website db:seed",
    "// === 部署相关 ===": "",
    "prepare": "husky || true",
    "precommit": "pnpm lint:fix && pnpm type-check",
    "prepush": "pnpm health && pnpm test"
  },
  "devDependencies": {
    "@swc/core": "^1.15.18",
    "dependency-cruiser": "^16.0.0",
    "@types/express": "^4.17.21",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "eslint": "^9.39.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.4",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.{js,ts,tsx}": [
      "prettier --write",
      "eslint --flag unstable_config_lookup_from_file --fix"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@parcel/watcher",
      "@prisma/client",
      "@prisma/engines",
      "@swc/core",
      "esbuild",
      "msgpackr-extract",
      "prisma",
      "sharp",
      "unrs-resolver"
    ],
    "overrides": {
      "shell-quote": "^1.8.4",
      "postcss": "^8.5.10",
      "vite": "7.3.6",
      "@babel/plugin-transform-modules-systemjs": "^7.29.4",
      "brace-expansion@1": "^1.1.13",
      "brace-expansion@5": "^5.0.6",
      "fast-uri": "^3.1.2",
      "file-type": "^21.3.2",
      "flatted": "^3.4.2",
      "js-yaml@4": "^4.2.0",
      "lodash": "^4.18.0",
      "multer": "^2.2.0",
      "path-to-regexp@0": "^0.1.13",
      "path-to-regexp@8": "^8.4.0",
      "picomatch@2": "^2.3.2",
      "picomatch@4": "^4.0.4",
      "qs": "^6.15.2",
      "yaml@2": "^2.8.3"
    }
  }
}
