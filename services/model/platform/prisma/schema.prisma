generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["metering", "model"]
}

// 平台库 18-schema cutover 后（commerce → metering 重构，model.* 表复数化）本代理模型已重映射。
// model schema 的 DDL 权威在 deploy/database/ddl/60_model.sql；metering 在 50_metering.sql。
// 本文件声明 Prisma Client 代理，供 ModelRegistryRepository 在服务内直接查询，无需跨服务 RPC。
//
// FLAG（metering 集成缺口 — 待 commerce 域解耦重构收口）：
//   旧 commerce.tenant_subscription_quota / tenant_usage_event / tenant_usage_summary 已被
//   metering.quota_pools / usage_events / usage_summary_* 取代，语义从 tenant 级 token 预算
//   改为 workspace+product+metric_key 的多池计量。本服务当前只有 tenantId，缺 workspace_id /
//   product_id / metric_key，且 usage_events/usage_summary_* 对 workspaces/products 有真实跨库 FK。
//   因此：读路径（配额/用量只读，就绪检查）已重映射到新表使查询可解；
//   配额“允许模型/自定义模型/period_tokens”等旧概念在新表无对应（模型授权已由 model_grants 承担）；
//   用量写路径（recordUsage）在拿到 workspace/product/metric 映射前无法落库，见 repository 内 FLAG。

// ── metering schema（订阅/配额/用量计量内核，只读代理 + 写路径待接入） ──

// 旧 TenantSubscriptionQuota → metering.quota_pools（workspace+product+metric 多池实时余量 SoT）。
model TenantSubscriptionQuota {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId        String    @map("workspace_id") @db.Uuid
  subscriptionId     String?   @map("subscription_id") @db.Uuid
  productId          String    @map("product_id") @db.Uuid
  metricKey          String    @map("metric_key") @db.VarChar(64)
  quotaLimit         BigInt    @map("quota_limit")
  quotaUsed          BigInt    @default(0) @map("quota_used")
  priority           Int       @default(100)
  componentRole      String    @default("primary") @map("component_role") @db.VarChar(16)
  poolSource         String    @default("subscription") @map("pool_source") @db.VarChar(32)
  resetPeriod        String    @default("none") @map("reset_period") @db.VarChar(16)
  periodAnchor       DateTime? @map("period_anchor") @db.Timestamptz(6)
  currentPeriodStart DateTime? @map("current_period_start") @db.Timestamptz(6)
  status             String    @default("active") @db.VarChar(32)
  retiredAt          DateTime? @map("retired_at") @db.Timestamptz(6)
  grantedBy          String?   @map("granted_by") @db.Uuid
  grantReason        String?   @map("grant_reason") @db.VarChar(256)
  effectiveAt        DateTime  @default(now()) @map("effective_at") @db.Timestamptz(6)
  expiresAt          DateTime? @map("expires_at") @db.Timestamptz(6)
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@index([workspaceId, productId, metricKey, priority], map: "idx_quota_pools_route")
  @@map("quota_pools")
  @@schema("metering")
}

// 旧 TenantUsageEvent → metering.usage_events（append-only，按月 RANGE 分区，复合 PK）。
// 写路径待接入（见 repository FLAG）；此处保留代理定义以生成 client。
model TenantUsageEvent {
  id              String   @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId     String   @map("workspace_id") @db.Uuid
  productId       String   @map("product_id") @db.Uuid
  metricKey       String   @map("metric_key") @db.VarChar(64)
  totalAmount     BigInt   @map("total_amount")
  requestedAmount BigInt?  @map("requested_amount")
  idempotencyKey  String?  @map("idempotency_key") @db.VarChar(128)
  requestId       String?  @map("request_id") @db.VarChar(128)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@id([id, createdAt])
  @@index([workspaceId, productId, metricKey], map: "idx_usage_events_route")
  @@index([idempotencyKey], map: "idx_usage_events_idempotency")
  @@index([requestId], map: "idx_usage_events_request_id")
  @@map("usage_events")
  @@schema("metering")
}

// 旧 TenantUsageSummary → metering.usage_summary_months（多维降采样汇总的“月”档，仅统计/看板）。
model TenantUsageSummary {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId  String   @map("workspace_id") @db.Uuid
  productId    String   @map("product_id") @db.Uuid
  metricKey    String   @map("metric_key") @db.VarChar(64)
  periodMonth  String   @map("period_month") @db.VarChar(8)
  totalAmount  BigInt   @default(0) @map("total_amount")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@unique([workspaceId, productId, metricKey, periodMonth], map: "uq_usage_summary_months")
  @@map("usage_summary_months")
  @@schema("metering")
}

// ── model schema（模型治理配置，只读/读写代理，DDL 权威 60_model.sql） ──

model ModelProvider {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  providerCode String    @unique(map: "uq_model_providers_provider_code") @map("provider_code") @db.VarChar(64)
  providerType String    @default("online") @map("provider_type") @db.VarChar(32)
  providerName String    @map("provider_name") @db.VarChar(128)
  description  String?   @db.VarChar(512)
  logoUrl      String?   @map("logo_url") @db.Text
  homepageUrl  String?   @map("homepage_url") @db.Text
  consoleUrl   String?   @map("console_url") @db.Text
  billingUrl   String?   @map("billing_url") @db.Text
  isActive     Boolean   @default(true) @map("is_active")
  config       Json?     @db.JsonB
  createdBy    String?   @map("created_by") @db.Uuid
  updatedBy    String?   @map("updated_by") @db.Uuid
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)

  models ModelDefinition[]

  @@index([isActive], map: "idx_model_providers_is_active")
  @@index([providerType], map: "idx_model_providers_type")
  @@index([deletedAt], map: "idx_model_providers_deleted_at")
  @@map("model_providers")
  @@schema("model")
}

// model.models：已退役旧 provider varchar 冗余列（provider_id 为唯一权威 provider 引用）。
// 服务侧 AiModelRecord.provider 由 providerRef.providerCode 派生（见 repository mapAiModel）。
model ModelDefinition {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  providerId        String?   @map("provider_id") @db.Uuid
  modelCode         String    @unique(map: "uq_models_model_code") @map("model_code") @db.VarChar(128)
  modelType         String    @default("chat") @map("model_type") @db.VarChar(32)
  protocol          String    @db.VarChar(64)
  modelName         String    @map("model_name") @db.VarChar(128)
  description       String?   @db.VarChar(512)
  endpointUrl       String    @map("endpoint_url") @db.Text
  contextWindow     Int?      @map("context_window")
  maxOutputTokens   Int?      @map("max_output_tokens")
  capabilities      String[]  @default([])
  supportsStreaming Boolean   @default(true) @map("supports_streaming")
  isActive          Boolean   @default(true) @map("is_active")
  sort              Int       @default(999)
  config            Json?     @db.JsonB
  createdBy         String?   @map("created_by") @db.Uuid
  updatedBy         String?   @map("updated_by") @db.Uuid
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt         DateTime? @map("deleted_at") @db.Timestamptz(6)

  providerRef ModelProvider?   @relation(fields: [providerId], references: [id])
  grants      ModelGrant[]
  priceRules  ModelPriceRule[]
  policies    ModelPolicy[]

  @@index([isActive], map: "idx_models_is_active")
  @@index([modelType], map: "idx_models_model_type")
  @@index([providerId], map: "idx_models_provider_id")
  @@index([deletedAt], map: "idx_models_deleted_at")
  @@map("models")
  @@schema("model")
}

model ModelGrant {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  modelId         String    @map("model_id") @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  applicationId   String?   @map("application_id") @db.Uuid
  applicationType String?   @map("application_type") @db.VarChar(32)
  agentId         String?   @map("agent_id") @db.Uuid
  priority        Int       @default(100)
  isActive        Boolean   @default(true) @map("is_active")
  reason          String?   @db.VarChar(512)
  expiresAt       DateTime? @map("expires_at") @db.Timestamptz(6)
  createdBy       String?   @map("created_by") @db.Uuid
  updatedBy       String?   @map("updated_by") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz(6)

  modelDef ModelDefinition @relation(fields: [modelId], references: [id])

  @@index([modelId], map: "idx_model_grants_model")
  @@index([tenantId], map: "idx_model_grants_tenant")
  @@index([applicationId], map: "idx_model_grants_application")
  @@index([applicationType], map: "idx_model_grants_application_type")
  @@index([agentId], map: "idx_model_grants_agent")
  @@index([isActive], map: "idx_model_grants_is_active")
  @@map("model_grants")
  @@schema("model")
}

model ModelPriceRule {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  modelId          String    @map("model_id") @db.Uuid
  billingMode      String    @default("token") @map("billing_mode") @db.VarChar(32)
  currency         String    @default("CNY") @db.VarChar(16)
  unitTokens       Int       @default(1000000) @map("unit_tokens")
  inputUnitPrice   Decimal   @default(0) @map("input_unit_price") @db.Decimal(18, 8)
  outputUnitPrice  Decimal   @default(0) @map("output_unit_price") @db.Decimal(18, 8)
  requestUnitPrice Decimal   @default(0) @map("request_unit_price") @db.Decimal(18, 8)
  isActive         Boolean   @default(true) @map("is_active")
  effectiveAt      DateTime  @default(now()) @map("effective_at") @db.Timestamptz(6)
  expiresAt        DateTime? @map("expires_at") @db.Timestamptz(6)
  createdBy        String?   @map("created_by") @db.Uuid
  updatedBy        String?   @map("updated_by") @db.Uuid
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  modelDef ModelDefinition @relation(fields: [modelId], references: [id])

  @@index([modelId], map: "idx_model_price_rules_model")
  @@index([effectiveAt], map: "idx_model_price_rules_effective")
  @@index([isActive], map: "idx_model_price_rules_is_active")
  @@map("model_price_rules")
  @@schema("model")
}

model ModelPolicy {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  modelId          String    @map("model_id") @db.Uuid
  tenantId         String?   @map("tenant_id") @db.Uuid
  name             String?   @db.VarChar(128)
  priority         Int       @default(100)
  maxConcurrent    Int?      @map("max_concurrent")
  rateLimitRpm     Int?      @map("rate_limit_rpm")
  rateLimitTpm     BigInt?   @map("rate_limit_tpm")
  rateLimitTpd     BigInt?   @map("rate_limit_tpd")
  maxContextTokens Int?      @map("max_context_tokens")
  isActive         Boolean   @default(true) @map("is_active")
  effectiveAt      DateTime  @default(now()) @map("effective_at") @db.Timestamptz(6)
  expiresAt        DateTime? @map("expires_at") @db.Timestamptz(6)
  createdBy        String?   @map("created_by") @db.Uuid
  updatedBy        String?   @map("updated_by") @db.Uuid
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  modelDef ModelDefinition @relation(fields: [modelId], references: [id])

  @@unique([modelId, tenantId], map: "uq_model_policies_model_tenant")
  @@index([modelId], map: "idx_model_policies_model")
  @@index([tenantId], map: "idx_model_policies_tenant")
  @@index([isActive], map: "idx_model_policies_is_active")
  @@map("model_policies")
  @@schema("model")
}
