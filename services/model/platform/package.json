{
  "name": "@vxture/service-model-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "description": "Vxture Model Platform - model registry, routing, quota and metering",
  "scripts": {
    "build": "pnpm -w build:backend-deps && esbuild src/main.ts --bundle --platform=node --format=cjs --target=node22 --outfile=dist/main.cjs --tsconfig=tsconfig.json --external:@nestjs/websockets/socket-module --external:@nestjs/microservices --external:@nestjs/microservices/microservices-module --external:@prisma/client",
    "dev": "pnpm run build && node dist/main.cjs",
    "start": "node dist/main.cjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint --fix src",
    "db:generate": "prisma generate --schema prisma/schema.prisma"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.1.28",
    "@nestjs/platform-express": "^11.0.0",
    "@prisma/client": "^6.0.0",
    "@vxture/core-config": "workspace:*",
    "@vxture/shared": "workspace:*",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.8",
    "esbuild": "^0.27.4",
    "prisma": "^6.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
