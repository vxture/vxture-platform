# ================================================================
# @vxture/bff-website — 包级环境变量说明
# ================================================================
# 本包无独立 .env.local 需求。
# JWT、DB、Redis、SMTP、端口等共享变量由根目录 .env.local 统一管理。
# OAuth 凭证（钉钉、飞书）在根目录 .env.local 中统一配置。
# ================================================================
# 如需单独覆盖，创建本包 .env.local 并填写以下变量。
# ================================================================

# ── 包专属端口（根目录已设置，无需重复填写）─────────────────────
# WEBSITE_BFF_PORT=3011

# ── Portal 基址（密码重置邮件链接 + OAuth 回调白名单）────────────
# WEBSITE_BASE_URL=http://localhost:3010
# CONSOLE_BASE_URL=http://localhost:3020

# ── 钉钉 OAuth（仅 website-bff 使用，禁止用于 admin 登录）────────
# DINGTALK_APP_KEY=your-dingtalk-app-key
# DINGTALK_APP_SECRET=your-dingtalk-app-secret
# DINGTALK_CALLBACK_TOKEN=your-callback-token
# DINGTALK_CALLBACK_AES_KEY=your-callback-aes-key
# 本地：http://localhost:8000/auth-api/auth/oauth/dingtalk/callback
# 生产：https://www.vxture.com/auth-api/auth/oauth/dingtalk/callback
# DINGTALK_REDIRECT_URI=http://localhost:8000/auth-api/auth/oauth/dingtalk/callback

# ── 飞书 OAuth（仅 website-bff 使用，禁止用于 admin 登录）────────
# FEISHU_APP_ID=your-feishu-app-id
# FEISHU_APP_SECRET=your-feishu-app-secret
# FEISHU_REDIRECT_URI=http://localhost:8000/auth-api/auth/oauth/feishu/callback
# 注意：飞书固定接口地址（AUTH_URL / ACCESS_TOKEN_URL / USER_INFO_URL）
#       硬编码在 feishu.service.ts 中，无需配置。
