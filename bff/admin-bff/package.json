{
  "name": "@vxture/bff-admin",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/main.ts",
  "types": "src/main.ts",
  "description": "Vxture platform operations BFF",
  "scripts": {
    "build": "pnpm -w build:backend-deps && pnpm run build:bundle",
    "build:bundle": "esbuild src/main.ts --bundle --platform=node --format=cjs --target=node22 --outfile=dist/main.cjs --tsconfig=tsconfig.json --external:@nestjs/websockets/socket-module --external:@nestjs/microservices --external:@nestjs/microservices/microservices-module",
    "dev": "pnpm run build && node dist/main.cjs",
    "start": "node dist/main.cjs",
    "boot-smoke": "node ../../scripts/guardrails/boot-smoke.mjs dist/main.cjs admin-bff",
    "type-check": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint --fix src",
    "test": "vitest run"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.1.28",
    "@nestjs/platform-express": "^11.0.0",
    "@vxture/core-api": "workspace:*",
    "@vxture/core-config": "workspace:*",
    "@vxture/core-mail": "workspace:*",
    "@vxture/core-oidc-rp": "workspace:*",
    "@vxture/core-utils": "workspace:*",
    "@vxture/service-promotion": "workspace:*",
    "@vxture/service-provisioning": "workspace:*",
    "@vxture/service-subscription": "workspace:*",
    "@vxture/shared": "workspace:*",
    "cookie-parser": "^1.4.7",
    "express": "^4.22.1",
    "ioredis": "^5.0.0",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^4.17.21",
    "@types/pg": "^8.16.0",
    "esbuild": "^0.28.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
