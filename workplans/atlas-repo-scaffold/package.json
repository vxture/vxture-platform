{
  "name": "vxture-atlas",
  "version": "0.0.0",
  "private": true,
  "description": "Atlas - Vxture's L1 model platform: unified model access, routing, quota and metering.",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm --filter @vxture/service-model-platform build",
    "type-check:all": "pnpm --filter @vxture/service-model-platform type-check",
    "lint": "pnpm --recursive --if-present lint",
    "lint:docs-numbering": "node scripts/guardrails/check-docs-numbering.mjs --strict",
    "lint:data-design": "node scripts/guardrails/check-data-architecture.mjs --strict",
    "lint:workflows": "node scripts/guardrails/check-workflows.mjs --strict"
  }
}
