# .env.example for atlas - authoritative reference for every supported
# variable. Copy to .env and fill in. .env is git-ignored and never committed.
# Convention: values below are the prod defaults; a "BETA OVERRIDES" note marks
# any key whose beta value differs. Secret keys are present-but-empty with a
# procurement note; real values are injected via env, never committed.
#
# services profile (product_240 section 2.5), not app profile: no Next.js, no
# portals/, no browser session. The C1 OIDC RP block below is RIGID ZONE per
# the template but currently UNUSED - Atlas has no end-user browser surface
# today (plan decision 4: operator UI stays in vxture-platform's admin/console,
# calling Atlas over the network). Keep the block present and inert rather than
# omitted, per product_240's no-selective-skip rule for the rigid zone; wire it
# only if/when Atlas gets its own browser-facing surface.

# --- Service ---
NODE_ENV=production
APP_PUBLISH_PORT=3100                    # unchanged from the in-monorepo service (services/model/platform); worker allocation TBD, see docs/50-deployment/00-index.md

# --- Database (atlas) ---
# Atlas owns a fully separate PHYSICAL database, not a schema in the shared
# platform DB and not a vxturebiz_atlas_{env}-style business-plane DB either -
# see docs/30-design/00-index.md for why. Runtime connects as the
# least-privilege service role, not the DB owner.
POSTGRES_DB=vxturestudio_modelruntime_main   # single physical DB name across prod/beta today - see TODO in docs/50-deployment/00-index.md on env-suffixing this once a beta host exists
POSTGRES_USER=atlas_svc
POSTGRES_PASSWORD=                       # procure: ATLAS_DB_SVC_PASSWORD
DATABASE_URL=postgresql://atlas_svc:@atlas-db:5432/vxturestudio_modelruntime_main

# --- Provider API keys (model-runtime; apiKeyEnvVar in the model registry must match one of these) ---
DOUBAO_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# --- C1 OIDC RP (rigid zone, currently UNUSED - see header note) ---
OIDC_ISSUER=https://accounts.vxture.com
OIDC_CLIENT_ID=atlas                     # BETA OVERRIDES: atlas-beta
OIDC_CLIENT_SECRET=                      # procure: platform-issued client secret
OIDC_REDIRECT_URI=https://atlas.vxture.com/auth/callback
OIDC_SCOPES=openid profile email phone
OIDC_POST_LOGOUT_REDIRECT_URI=https://atlas.vxture.com/
OIDC_RP_ENABLED=off                      # off until Atlas has a browser-facing surface to protect
RP_SESSION_TTL=2592000
RP_SESSION_COOKIE_NAME=__Host-vx_rp_session   # dev over http: vx_rp_session
REDIS_URL=redis://atlas-redis:6379       # only needed once OIDC_RP_ENABLED=on; omit the redis compose service until then

# --- C2 entitlement / platform client ---
# PLATFORM_API_URL must be an INTERNAL (tailnet) base - see the S2S egress
# guard note carried over from the product_240 template. Unset -> Mock
# resolver, no live entitlements.
PLATFORM_API_URL=
PLATFORM_INTERNAL_AUTH_TOKEN=            # transitional; product_210 token exchange is the target state (plan decision, Phase 5) - counterpart of the platform's own AUTH_INTERNAL_TOKEN

# --- C3 provisioning webhook / usage consume ---
PROVISION_WEBHOOK_SECRET=                # procure: ATLAS_PROVISION_WEBHOOK_SECRET (platform key)
PROVISION_WEBHOOK_SECRET_NEXT=           # optional, rotation overlap
INTERNAL_JOB_TOKEN=                      # gates the usage-flush job (C3 consume buffer -> platform /usage/consume)
