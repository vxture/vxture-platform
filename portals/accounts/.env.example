# ================================================================
# @vxture/accounts — frontend build-time env (NEXT_PUBLIC_*)
# ================================================================
# These are baked at build time (Next.js). In prod they are passed as Docker
# build-args (deploy/docker/Dockerfile.nextjs) from CI secrets
# (.github/workflows/docker-build.yml). For local dev, copy to .env.local.
# ================================================================

# Public base of the OIDC API the login form POSTs to (/oidc/authorize/login).
# Prod: same-origin accounts surface (https://accounts.vxture.com).
# Local dev: the auth-bff origin.
NEXT_PUBLIC_OIDC_API_BASE=http://localhost:3090

# Cloudflare Turnstile site keys (public). Empty → widget is not rendered and the
# UI does not gate on it (the IdP still enforces server-side when CF_TURNSTILE_ENABLED).
# Operator realm reuses the ADMIN site key; tenant realm uses the TENANT key.
NEXT_PUBLIC_CF_TURNSTILE_TENANT_SITE_KEY=
NEXT_PUBLIC_CF_TURNSTILE_ADMIN_SITE_KEY=
